{
  "$schema": "https://emdashcms.com/seed.schema.json",
  "version": "1",
  "meta": {
    "name": "Bravada for Astro (minimal)",
    "description": "Structure-only seed: collections, taxonomies, menus, widget areas and the Bravada sections, with no demo content. Start here for a clean site."
  },
  "settings": {
    "title": "Bravada for Astro",
    "tagline": "Clear, clean and simply gorgeous",
    "showPostAuthor": true,
    "showPostNav": true
  },
  "collections": [
    {
      "slug": "posts",
      "label": "Posts",
      "labelSingular": "Post",
      "supports": [
        "drafts",
        "revisions",
        "search",
        "seo"
      ],
      "commentsEnabled": true,
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true,
          "searchable": true
        },
        {
          "slug": "featured_image",
          "label": "Featured Image",
          "type": "image"
        },
        {
          "slug": "content",
          "label": "Content",
          "type": "portableText",
          "searchable": true
        },
        {
          "slug": "excerpt",
          "label": "Excerpt",
          "type": "text"
        }
      ]
    },
    {
      "slug": "pages",
      "label": "Pages",
      "labelSingular": "Page",
      "supports": [
        "drafts",
        "revisions",
        "search"
      ],
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true,
          "searchable": true
        },
        {
          "slug": "header_image",
          "label": "Header image",
          "type": "image"
        },
        {
          "slug": "content",
          "label": "Content",
          "type": "portableText",
          "searchable": true
        },
        {
          "slug": "layout",
          "label": "Layout",
          "type": "select",
          "options": {
            "choices": [
              {
                "value": "none",
                "label": "No sidebars"
              },
              {
                "value": "left",
                "label": "Left Sidebar"
              },
              {
                "value": "right",
                "label": "Right Sidebar"
              },
              {
                "value": "two-left",
                "label": "Two sidebars left"
              },
              {
                "value": "two-right",
                "label": "Two sidebars right"
              },
              {
                "value": "sided",
                "label": "Two sidebars sided"
              }
            ]
          },
          "default": "none"
        },
        {
          "slug": "sidebar",
          "label": "Sidebar widgets",
          "type": "select",
          "options": {
            "choices": [
              {
                "value": "page-sidebar",
                "label": "Pages & products (default)"
              },
              {
                "value": "sidebar-b",
                "label": "Search & posts"
              },
              {
                "value": "sidebar",
                "label": "Blog sidebar"
              }
            ]
          },
          "default": "page-sidebar"
        },
        {
          "slug": "excerpt",
          "label": "Excerpt",
          "type": "text"
        }
      ]
    },
    {
      "slug": "portfolio",
      "label": "Portfolio",
      "labelSingular": "Project",
      "supports": [
        "drafts",
        "revisions",
        "search",
        "seo"
      ],
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true,
          "searchable": true
        },
        {
          "slug": "featured_image",
          "label": "Featured Image",
          "type": "image"
        },
        {
          "slug": "date",
          "label": "Project date",
          "type": "string"
        },
        {
          "slug": "content",
          "label": "Content",
          "type": "portableText",
          "searchable": true
        }
      ]
    },
    {
      "slug": "products",
      "label": "Products",
      "labelSingular": "Product",
      "supports": [
        "drafts",
        "revisions",
        "search",
        "seo"
      ],
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true,
          "searchable": true
        },
        {
          "slug": "featured_image",
          "label": "Product Image",
          "type": "image"
        },
        {
          "slug": "price",
          "label": "Price",
          "type": "string"
        },
        {
          "slug": "price_old",
          "label": "Previous price (sale strikethrough)",
          "type": "string"
        },
        {
          "slug": "rating",
          "label": "Rating (0-5)",
          "type": "number"
        },
        {
          "slug": "button",
          "label": "Button label",
          "type": "string",
          "default": "Add to basket"
        },
        {
          "slug": "stock",
          "label": "Stock note",
          "type": "string"
        },
        {
          "slug": "excerpt",
          "label": "Short description",
          "type": "text",
          "searchable": true
        },
        {
          "slug": "content",
          "label": "Description",
          "type": "portableText",
          "searchable": true
        },
        {
          "slug": "sku",
          "label": "SKU",
          "type": "string"
        },
        {
          "slug": "gallery",
          "label": "Gallery images",
          "type": "json"
        },
        {
          "slug": "variants",
          "label": "Variants (label + options)",
          "type": "json"
        },
        {
          "slug": "reviews",
          "label": "Reviews",
          "type": "json"
        },
        {
          "slug": "oos",
          "label": "Out of stock",
          "type": "boolean"
        }
      ]
    }
  ],
  "taxonomies": [
    {
      "name": "category",
      "label": "Categories",
      "labelSingular": "Category",
      "hierarchical": true,
      "collections": [
        "posts"
      ],
      "terms": []
    },
    {
      "name": "tag",
      "label": "Tags",
      "labelSingular": "Tag",
      "hierarchical": false,
      "collections": [
        "posts"
      ],
      "terms": []
    },
    {
      "name": "project-type",
      "label": "Project Types",
      "labelSingular": "Project Type",
      "hierarchical": false,
      "collections": [
        "portfolio"
      ],
      "terms": []
    },
    {
      "name": "project-tag",
      "label": "Project Tags",
      "labelSingular": "Project Tag",
      "hierarchical": false,
      "collections": [
        "portfolio"
      ],
      "terms": []
    },
    {
      "name": "product-category",
      "label": "Product Categories",
      "labelSingular": "Product Category",
      "hierarchical": false,
      "collections": [
        "products"
      ],
      "terms": []
    }
  ],
  "bylines": [],
  "menus": [
    {
      "name": "primary",
      "label": "Primary",
      "items": [
        {
          "label": "Home",
          "url": "/",
          "type": "custom"
        },
        {
          "label": "Blog",
          "url": "/posts",
          "type": "custom"
        }
      ]
    }
  ],
  "widgetAreas": [
    {
      "name": "sidebar",
      "label": "Sidebar",
      "description": "Widget area displayed on single post pages",
      "widgets": [
        {
          "type": "component",
          "componentId": "core:search",
          "title": "Search"
        },
        {
          "type": "component",
          "componentId": "core:categories",
          "title": "Categories"
        },
        {
          "type": "component",
          "componentId": "core:tags",
          "title": "Tags"
        },
        {
          "type": "component",
          "componentId": "core:recent-posts",
          "title": "Recent Posts",
          "settings": {
            "count": 5,
            "showDate": true
          }
        }
      ]
    },
    {
      "name": "footer",
      "label": "Footer",
      "description": "Three widget columns in the dark site footer",
      "widgets": []
    },
    {
      "name": "sidebar-b",
      "label": "Secondary Sidebar",
      "description": "Second sidebar for two-sidebar page layouts",
      "widgets": [
        {
          "type": "content",
          "content": [
            {
              "_type": "bravada.search",
              "_key": "sb-search",
              "placeholder": "Search"
            }
          ]
        },
        {
          "type": "content",
          "content": [
            {
              "_type": "bravada.postswidget",
              "_key": "sb-posts",
              "limit": 3
            }
          ]
        },
        {
          "type": "content",
          "content": [
            {
              "_type": "bravada.tabswidget",
              "_key": "sb-tabs",
              "limit": 4
            }
          ]
        }
      ]
    },
    {
      "name": "page-sidebar",
      "label": "Page Sidebar",
      "description": "Primary sidebar for page layouts",
      "widgets": []
    }
  ],
