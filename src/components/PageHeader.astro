---
import { getSiteSettings } from "emdash";
/**
 * Bravada inner-page header (#header-image-main, fullscreen): every
 * non-landing page opens on a full-viewport image under the demo's
 * gradient scrim, with the page title centered in Playfair — its
 * letters running the same gold break-up animation as the slider —
 * an optional meta line, and breadcrumbs pinned to the bottom edge.
 * Pages using it pass overHero to Base so the menu floats on top.
 */
interface Crumb {
	label: string;
	href?: string;
}

interface Props {
	title: string;
	/** Small line under the title (entry meta, result counts, …) */
	subtitle?: string;
	/** Header image URL; defaults to the demo's lake panorama */
	image?: string;
	imageAlt?: string;
	crumbs?: Crumb[];
	/** Visual-editing attributes spread onto the title */
	titleAttrs?: Record<string, string>;
}

const DEFAULT_IMAGE = "/images/demo/static.jpg";

const {
	title,
	subtitle,
	image,
	imageAlt = "",
	crumbs = [],
	titleAttrs = {},
} = Astro.props;

// Admins can swap every inner-page header photo from the admin
// (Settings → SEO → default OG image); the demo panorama is the
// fallback when neither a per-page image nor a site default is set.
const settings = await getSiteSettings();
const headerImage = image ?? settings?.seo?.defaultOgImage?.url ?? DEFAULT_IMAGE;
---

<section class="page-hero full-bleed">
	<img class="page-hero-image" src={headerImage} alt={imageAlt} loading="eager" fetchpriority="high" />
	<div class="page-hero-caption">
		<div class="page-hero-caption-inside">
			<h1 class="page-hero-title breakup-title" {...titleAttrs}>{title}</h1>
			{subtitle && <p class="page-hero-sub">{subtitle}</p>}
			<slot name="meta" />
		</div>
	</div>
	{
		crumbs.length > 0 && (
			<nav class="page-hero-crumbs" aria-label="Breadcrumb">
				<a href="/" class="crumb-chip" aria-label="Home">
					<svg
						width="13"
						height="13"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
						><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg
					>
				</a>
				{crumbs.map((crumb) =>
					crumb.href ? (
						<a href={crumb.href} class="crumb-chip">
							{crumb.label}
						</a>
					) : (
						<span class="crumb-chip crumb-current">{crumb.label}</span>
					),
				)}
			</nav>
		)
	}
</section>

<script>
	import { initTitleBreakup } from "../utils/breakup-client";

	initTitleBreakup(".page-hero-title");

	// cryoutHeaderParallax: as the page scrolls, the scrim deepens
	// toward black, the caption fades away, and the image crop drifts
	const hero = document.querySelector<HTMLElement>(".page-hero");
	const heroImg = hero?.querySelector<HTMLElement>(".page-hero-image");
	const heroCap = hero?.querySelector<HTMLElement>(".page-hero-caption");
	const heroCrumbs = hero?.querySelector<HTMLElement>(".page-hero-crumbs");
	if (hero && heroImg) {
		const baseOp = 0.6;
		let ticking = false;
		const update = () => {
			ticking = false;
			const h = heroImg.getBoundingClientRect().height || 1;
			const ratio = Math.max(0, Math.min(100, (window.scrollY / h) * 100));
			hero.style.setProperty(
				"--scrim-op",
				String(Math.min(1, baseOp + 1.5 * ((ratio * (1 - baseOp)) / 100))),
			);
			const fade = String(Math.max(0, 1 - ratio / 100));
			if (heroCap) heroCap.style.opacity = fade;
			if (heroCrumbs) heroCrumbs.style.opacity = fade;
			heroImg.style.objectPosition = `center ${50 + ratio / 2}%`;
		};
		window.addEventListener(
			"scroll",
			() => {
				if (!ticking) {
					ticking = true;
					requestAnimationFrame(update);
				}
			},
			{ passive: true },
		);
		update();
	}
</script>

<style>
	.page-hero {
		position: relative;
		overflow: hidden;
		text-align: center;
		background-color: var(--tint-slider);
	}

	.page-hero-image {
		display: block;
		width: 100%;
		height: 100vh;
		height: 100svh;
		min-height: 420px;
		object-fit: cover;
	}

	/* The demo's blue→umber scrim at 0.6; deepens toward 1 as the
	   page scrolls (cryoutHeaderParallax) via --scrim-op */
	.page-hero::after {
		content: "";
		position: absolute;
		z-index: 2;
		inset: 0;
		background: linear-gradient(180deg, #08415c 0%, #1c110a 100%);
		opacity: var(--scrim-op, 0.6);
		pointer-events: none;
	}

	.page-hero-caption {
		position: absolute;
		z-index: 3;
		inset: 0;
		display: flex;
		flex-flow: column;
		justify-content: center;
		padding: 85px 2.5em 0;
		color: #ffffff;
	}

	.page-hero-caption-inside {
		max-width: 85%;
		margin: 0 auto;
	}

	.page-hero-title {
		margin: 0;
		font-family: var(--font-heading);
		font-size: clamp(2.5em, 5vw, 5em);
		line-height: 1.3;
		font-weight: 700;
		color: #ffffff;
		opacity: 0;
		animation: 0.5s 0.25s page-hero-in ease-out forwards;
	}

	.page-hero-sub {
		margin: 1.5em auto 0;
		max-width: 80%;
		font-size: 1.1em;
		font-weight: 300;
		letter-spacing: 1px;
		opacity: 0;
		animation: 0.5s 0.5s page-hero-in ease-out forwards;
	}

	.page-hero-caption-inside :global([slot="meta"]),
	.page-hero-caption-inside :global(.page-hero-meta) {
		opacity: 0;
		animation: 0.5s 0.5s page-hero-in ease-out forwards;
	}

	@keyframes page-hero-in {
		from {
			opacity: 0;
			transform: translateX(-40px);
		}

		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	/* Breadcrumbs pinned bottom-center: muted translucent chips
	   (demo: rgba(255,255,255,.2) plates at 50% element opacity, 6px
	   apart). We sit slightly above the demo's opacity for legibility
	   and restore full strength on hover/keyboard focus. */
	.page-hero-crumbs {
		position: absolute;
		z-index: 4;
		left: 0;
		right: 0;
		bottom: 1.2em;
		display: flex;
		align-items: stretch;
		justify-content: center;
		gap: 6px;
		font-size: 0.81em;
		color: #ffffff;
	}

	.crumb-chip {
		display: inline-flex;
		align-items: center;
		padding: 5px 10px;
		background: rgba(255, 255, 255, 0.2);
		color: #ffffff;
		text-decoration: none;
		line-height: 1.4;
		opacity: 0.6;
		transition: 0.2s ease-out opacity;
	}

	a.crumb-chip:hover,
	a.crumb-chip:focus-visible {
		opacity: 1;
		color: #ffffff;
	}

	a.crumb-chip:focus-visible {
		outline: 2px solid rgba(255, 255, 255, 0.8);
		outline-offset: 1px;
	}

	@media (prefers-reduced-motion: reduce) {
		.page-hero-title,
		.page-hero-sub {
			animation: none;
			opacity: 1;
		}
	}

	@media (max-width: 800px) {
		.page-hero-caption {
			font-size: 0.8em;
		}
	}
</style>
