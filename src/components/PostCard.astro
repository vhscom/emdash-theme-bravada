---
/**
 * Bravada article card (#lp-posts / .content-masonry .article-inner):
 * a flat white card with a category strip above the featured image,
 * Playfair title (gold on hover, like the demo), light author/date
 * meta, excerpt, and a "Read more" link whose arrow slides in.
 */
import type { MediaValue, ContentBylineCredit } from "emdash";
import { Image } from "emdash/ui";

interface Props {
	title: string;
	excerpt?: string;
	featuredImage?: MediaValue | string;
	href: string;
	date?: Date;
	readingTime?: number;
	categories?: Array<{ slug: string; label: string }>;
	tags?: Array<{ slug: string; label: string }>;
	bylines?: ContentBylineCredit[];
}

const {
	title,
	excerpt,
	featuredImage,
	href,
	date,
	readingTime,
	categories,
	tags,
	bylines,
} = Astro.props;

const formattedDate = date
	? date.toLocaleDateString("en-US", {
			year: "numeric",
			month: "long",
			day: "numeric",
		})
	: null;
const author = bylines?.[0]?.byline.displayName;
---

<article class="post-card">
	{
		categories && categories.length > 0 && (
			<div class="card-categories">
				{categories.map((cat, i) => (
					<>
						{i > 0 && <span class="sep">, </span>}
						<a href={`/category/${cat.slug}`}>{cat.label}</a>
					</>
				))}
			</div>
		)
	}
	{
		featuredImage && (
			<a href={href} class="card-image" tabindex="-1" aria-hidden="true">
				<Image image={featuredImage} />
			</a>
		)
	}
	<div class="card-body">
		<h2 class="card-title-row">
			<a href={href} class="card-title-link"
				><span class="card-title">{title}</span></a
			>
		</h2>
		<div class="card-meta">
			{author && <span class="card-author">{author}</span>}
			{author && formattedDate && <span class="sep">·</span>}
			{formattedDate && <time>{formattedDate}</time>}
			{readingTime && <span class="sep">·</span>}
			{readingTime && <span>{readingTime} min</span>}
		</div>
		{excerpt && <p class="card-excerpt">{excerpt}</p>}
		{
			tags && tags.length > 0 && (
				<div class="card-tags">
					{tags.slice(0, 3).map((tag) => (
						<a href={`/tag/${tag.slug}`} class="card-tag">
							{tag.label}
						</a>
					))}
				</div>
			)
		}
		<footer class="card-continue">
			<a href={href} class="continue-reading-link">
				Read more<span class="continue-arrow">→</span>
				<span class="sr-only">“{title}”</span>
			</a>
		</footer>
	</div>
</article>

<style>
	.post-card {
		display: flex;
		flex-direction: column;
		background: var(--color-surface);
	}

	.card-categories {
		padding: var(--spacing-3) var(--spacing-5);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.card-categories a {
		color: var(--color-muted);
		text-decoration: none;
		transition: color 0.2s ease-out;
	}

	.card-categories a:hover {
		color: var(--color-brand-hover);
	}

	.card-image {
		display: block;
		overflow: hidden;
	}

	.card-image :global(img) {
		display: block;
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		transition: 0.4s ease-out transform;
	}

	.post-card:hover .card-image :global(img) {
		transform: scale(1.05);
	}

	.card-body {
		display: flex;
		flex-direction: column;
		flex: 1;
		padding: var(--spacing-5);
	}

	.card-title-row {
		margin: 0 0 var(--spacing-2);
	}

	.card-title-link {
		text-decoration: none;
		color: inherit;
	}

	.card-title {
		font-family: var(--font-heading);
		font-size: 1.7rem;
		line-height: 1.2;
		font-weight: 700;
		color: var(--color-heading);
		transition: color 0.25s ease-out;
	}

	.post-card:hover .card-title,
	.card-title-link:hover .card-title {
		color: var(--color-gold);
	}

	.card-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		column-gap: var(--spacing-2);
		margin-bottom: var(--spacing-3);
		font-size: var(--font-size-sm);
		font-weight: 300;
		color: var(--color-muted);
	}

	.card-excerpt {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-top: var(--spacing-3);
	}

	.card-tag {
		font-size: var(--font-size-xs);
		font-style: italic;
		color: var(--color-muted);
		text-decoration: none;
	}

	.card-tag:hover {
		color: var(--color-brand-hover);
	}

	/* Read more with Bravada's sliding arrow */
	.card-continue {
		margin-top: auto;
		padding-top: var(--spacing-4);
	}

	.continue-reading-link {
		font-weight: 700;
		font-size: 0.9em;
		text-decoration: none;
		color: var(--color-gold);
		transition: 0.2s ease-out all;
	}

	.continue-arrow {
		display: inline-block;
		margin-left: -10px;
		padding-left: 5px;
		opacity: 0;
		transition: all 0.2s ease-out;
	}

	.continue-reading-link:hover .continue-arrow,
	.continue-reading-link:focus-visible .continue-arrow {
		margin-left: 0;
		opacity: 1;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
