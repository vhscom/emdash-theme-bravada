---
/**
 * Shared portfolio term archive (project-type + project-tag routes):
 * the two routes are identical apart from the taxonomy and one word
 * in the meta description.
 */
import { getEmDashCollection, type TaxonomyTerm } from "emdash";
import Base from "../layouts/Base.astro";
import PageHeader from "./PageHeader.astro";
import ProjectShell from "../layouts/ProjectShell.astro";
import ProjectGrid from "./blocks/ProjectGrid.astro";
import { getMediaUrl } from "../utils/media-url";

interface Props {
	taxonomy: "project-type" | "project-tag";
	/** Resolved term — the route owns slug decoding and the 404 rewrite */
	term: TaxonomyTerm;
}

const { taxonomy, term } = Astro.props;

const { entries: projects, cacheHint } = await getEmDashCollection("portfolio", {
	where: { [taxonomy]: term.slug },
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const items = projects.map((p) => ({
	image: getMediaUrl(p.data.featured_image),
	title: p.data.title,
	url: `/portfolio/${p.id}`,
}));

const description =
	taxonomy === "project-type"
		? `Portfolio projects in ${term.label}.`
		: `Portfolio projects tagged ${term.label}.`;
---

<Base title={`${term.label} projects`} description={description} overHero>
	<PageHeader
		title={term.label}
		excerpt={term.description}
		crumbs={[{ label: "Projects", href: "/portfolio" }, { label: term.label }]}
	/>
	<ProjectShell>
		<ProjectGrid node={{ items }} />
	</ProjectShell>
</Base>
