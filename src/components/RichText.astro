---
/**
 * PortableText with the theme's custom Bravada block types registered.
 * Use this instead of importing PortableText directly on any surface
 * that renders editor content, so sections carrying bravada.* blocks
 * (hero sliders, icon blocks, boxes, text bands, portfolio grids,
 * testimonials) render everywhere.
 */
import { PortableText } from "emdash/ui";
import type { ComponentProps } from "astro/types";
import Hero from "./blocks/Hero.astro";
import FeatureBlocks from "./blocks/FeatureBlocks.astro";
import Boxes from "./blocks/Boxes.astro";
import TextBand from "./blocks/TextBand.astro";
import Portfolio from "./blocks/Portfolio.astro";
import Testimonials from "./blocks/Testimonials.astro";
import WidgetPortfolio from "./blocks/WidgetPortfolio.astro";

type Props = ComponentProps<typeof PortableText>;

const { value, components } = Astro.props;

const bravadaTypes = {
	"bravada.hero": Hero,
	"bravada.blocks": FeatureBlocks,
	"bravada.boxes": Boxes,
	"bravada.text": TextBand,
	"bravada.portfolio": Portfolio,
	"bravada.testimonials": Testimonials,
	"bravada.widgetportfolio": WidgetPortfolio,
};
---

<PortableText
	value={value}
	components={{ ...components, type: { ...bravadaTypes, ...components?.type } }}
/>
