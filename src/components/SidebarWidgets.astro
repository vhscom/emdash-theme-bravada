---
/**
 * A Bravada page sidebar (#primary/#secondary): widgets from the
 * named area rendered flat on the page sheet — Playfair gold-strip
 * titles, hairline list rules — exactly like the demo's layout pages.
 * Content widgets render through the theme's RichText so they can
 * carry custom blocks (products, posts widget, tabs, search…). All
 * of it is admin-editable under widget areas.
 */
import { getWidgetArea } from "emdash";
import RichText from "./RichText.astro";

interface Props {
	name: string;
}

const { name } = Astro.props;
const area = await getWidgetArea(name);
---

<aside class="bravada-sidebar">
	{
		area?.widgets.map((widget) => (
			<section class="widget">
				{widget.title && <h2 class="widget__title">{widget.title}</h2>}
				{widget.type === "content" && widget.content && (
					<div class="widget__content">
						<RichText value={widget.content} />
					</div>
				)}
			</section>
		))
	}
</aside>

<style>
	.bravada-sidebar {
		display: flex;
		flex-direction: column;
		gap: 2.5em;
		font-size: var(--font-size-sm);
	}

	.widget__title {
		display: inline-block;
		margin: 0 0 1em;
		font-family: var(--font-heading);
		font-size: 1.2em;
		font-weight: 700;
		line-height: 1.6;
		color: var(--color-heading);
		background-image: linear-gradient(
			to bottom,
			var(--gold-strip) 0%,
			var(--gold-strip) 100%
		);
		background-repeat: no-repeat;
		background-size: 100% 0.5em;
		background-position: 0 85%;
	}

	.widget :global(ul:not([class])) {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.widget :global(ul:not([class]) li) {
		padding: 0.5em 0;
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.widget :global(ul:not([class]) li:last-child) {
		border-bottom: none;
	}

	.widget :global(ul:not([class]) a) {
		color: var(--color-teal);
		text-decoration: none;
		transition: color 0.2s ease-out;
	}

	.widget :global(ul:not([class]) a:hover) {
		color: var(--color-gold);
	}
</style>
