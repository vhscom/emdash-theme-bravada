---
/**
 * Gold social glyph for a social-menu item (footer + burger menu).
 * Icon is picked from the item label; unknown networks get the demo's
 * link glyph. The social menu itself is admin-editable (Menus →
 * Social), so site users control which icons appear.
 */
interface Props {
	label: string;
	size?: number;
}

const { label, size = 18 } = Astro.props;
const key = label.toLowerCase();
---

{
	key.includes("mastodon") ? (
		<svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.27 5.59c-.36-2.68-2.7-4.8-5.47-5.2C17.33.32 15.57 0 11.44 0h-.03C7.28 0 6.39.32 5.92.39 3.23.79 1.13 2.69.53 5.4.24 6.74.21 8.22.26 9.58c.08 1.95.09 3.9.28 5.86.13 1.3.35 2.58.68 3.84.6 2.36 3.06 4.32 5.47 5.13 2.58.84 5.35.98 8 .4.29-.06.58-.14.86-.23.64-.2 1.39-.42 1.94-.8.01 0 .01-.01.01-.02v-1.98s0-.01-.01-.02h-.02c-1.7.4-3.44.6-5.19.6-3.01 0-3.82-1.43-4.05-2.02a6.26 6.26 0 0 1-.35-1.6c0-.01 0-.02.01-.02h.02c1.67.4 3.39.6 5.11.6.41 0 .83 0 1.24-.01 1.73-.05 3.56-.14 5.26-.47.04-.01.09-.02.12-.03 2.69-.52 5.24-2.14 5.5-6.24.01-.16.04-1.69.04-1.86 0-.57.18-4.02-.03-6.14zm-4.13 10.18h-2.83V8.85c0-1.46-.61-2.2-1.84-2.2-1.36 0-2.04.88-2.04 2.61v3.79h-2.81V9.26c0-1.73-.68-2.61-2.04-2.61-1.23 0-1.84.74-1.84 2.2v6.92H2.91V8.64c0-1.46.37-2.61 1.12-3.47.77-.85 1.78-1.29 3.03-1.29 1.45 0 2.55.56 3.28 1.67l.7 1.19.71-1.19c.73-1.11 1.83-1.67 3.28-1.67 1.25 0 2.26.44 3.03 1.29.75.86 1.12 2.01 1.12 3.47v7.13z" /></svg>
	) : key.includes("facebook") ? (
		<svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.09 10.13 24v-8.44H7.08v-3.49h3.04V9.41c0-3.02 1.8-4.7 4.54-4.7 1.31 0 2.68.24 2.68.24v2.97h-1.5c-1.5 0-1.96.93-1.96 1.89v2.26h3.32l-.53 3.49h-2.8V24C19.62 23.09 24 18.1 24 12.07z" /></svg>
	) : key.includes("twitter") || key === "x" ? (
		<svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.24 2.25h3.31l-7.23 8.26 8.5 11.24h-6.66l-5.21-6.82-5.97 6.82H1.67l7.73-8.84L1.25 2.25h6.83l4.71 6.23 5.45-6.23zm-1.16 17.52h1.83L7.08 4.13H5.12l11.96 15.64z" /></svg>
	) : key.includes("rss") ? (
		<svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3.43 20.57a2.57 2.57 0 1 1 0-5.14 2.57 2.57 0 0 1 0 5.14zM.86 9.71v3.72c5.36 0 9.71 4.35 9.71 9.71h3.72c0-7.42-6.01-13.43-13.43-13.43zM.86.86v3.71C11.4 4.57 19.43 12.6 19.43 23.14h3.71C23.14 10.83 13.17.86.86.86z" /></svg>
	) : (
		<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" /><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" /></svg>
	)
}
