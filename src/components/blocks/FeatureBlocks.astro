---
/**
 * bravada.blocks — Bravada's landing-page icon blocks (.lp-blocks).
 * Two demo variants:
 *   "light" (lp-blocks1): white inset band on a warm tint, centered
 *     white cards with thin teal line icons that swap out/in on hover
 *     and a gold highlighter strip through the title.
 *   "dark" (lp-blocks2): dark #1E3231 band, white cards with a teal
 *     square icon tile overlapping the top-left, Playfair teal titles.
 * Icons name a built-in line icon (trophy, briefcase, notebook,
 * megaphone, pointer, smartphone, screen, layers, folder, check,
 * plus); any other value renders as literal text/emoji.
 */
import SectionHeader from "./SectionHeader.astro";

interface BlockItem {
	icon?: string;
	title?: string;
	text?: string;
	url?: string;
}

interface BlocksNode {
	title?: string;
	description?: string;
	variant?: "light" | "dark";
	columns?: number;
	items?: BlockItem[];
}

// astro-portabletext hands custom type components the block as `node`
const { node } = Astro.props as { node: BlocksNode };
const { title, description, variant = "light", columns = 3, items = [] } = node;
const cols = Math.min(Math.max(columns, 2), 4);

// Feather-style line icon paths (24×24 viewBox, stroke drawn)
const ICONS: Record<string, string> = {
	trophy:
		'<path d="M8 21h8M12 17v4M7 4h10v5a5 5 0 0 1-10 0V4zM7 6H4a1 1 0 0 0-1 1c0 2 1.5 3.5 4 3.5M17 6h3a1 1 0 0 1 1 1c0 2-1.5 3.5-4 3.5"/>',
	briefcase:
		'<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
	notebook:
		'<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
	megaphone:
		'<path d="M3 11v3a1 1 0 0 0 1 1h2l3.6 4.3a1 1 0 0 0 1.4.1V5.6a1 1 0 0 0-1.4.1L6 10H4a1 1 0 0 0-1 1z"/><path d="M14 8.6a5 5 0 0 1 0 7.8M17 5.5a9 9 0 0 1 0 13"/>',
	pointer:
		'<path d="M12 22V8M12 22l-4-4M12 22l4-4"/><path d="M12 2a3 3 0 0 1 3 3v3h-6V5a3 3 0 0 1 3-3z"/>',
	smartphone:
		'<rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18"/>',
	screen:
		'<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
	layers:
		'<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 12 12 17 22 12"/><polyline points="2 17 12 22 22 17"/>',
	folder:
		'<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>',
	check:
		'<path d="M4 15h8M4 11h6M4 7h8"/><polyline points="14 15 17 18 22 12"/>',
	plus: '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>',
};

function iconSvg(name: string | undefined): string | null {
	if (!name) return null;
	const paths = ICONS[name.toLowerCase()];
	if (!paths) return null;
	return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${paths}</svg>`;
}
---

<section
	class:list={[
		"lp-blocks",
		"full-bleed",
		variant === "dark" ? "lp-blocks-dark" : "lp-blocks-light",
	]}
>
	<SectionHeader title={title} description={description} />
	<div class:list={["lp-blocks-inside", `lp-rows-${cols}`]} style={`--lp-cols: ${cols}`}>
		{
			items.map((item) => {
				const svg = iconSvg(item.icon);
				return (
					<div class="lp-block aos">
						{item.icon && (
							<div class="lp-block-icon">
								{svg ? (
									<>
										<span class="blicon" set:html={svg} />
										<span class="blicon" set:html={svg} />
									</>
								) : (
									<>
										<span class="blicon">{item.icon}</span>
										<span class="blicon">{item.icon}</span>
									</>
								)}
							</div>
						)}
						<div class="lp-block-content">
							{item.title &&
								(item.url ? (
									<h4 class="lp-block-title">
										<a href={item.url}>{item.title}</a>
									</h4>
								) : (
									<h4 class="lp-block-title">{item.title}</h4>
								))}
							{item.text && <div class="lp-block-text">{item.text}</div>}
						</div>
					</div>
				);
			})
		}
	</div>
</section>

<style>
	.lp-blocks {
		overflow: hidden;
	}

	.lp-blocks-light {
		background-color: var(--tint-blocks1);
	}

	.lp-blocks-dark {
		background-color: var(--color-footer-bg);
	}

	.lp-blocks-inside {
		display: grid;
		grid-template-columns: repeat(var(--lp-cols, 3), 1fr);
		max-width: calc(var(--wide-width) - 5em);
		margin: 2em auto;
	}

	.lp-blocks-light .lp-blocks-inside {
		background-color: var(--color-surface);
	}

	.lp-block {
		position: relative;
		overflow: hidden;
		padding: 2em;
		background-color: var(--color-surface);
		text-align: center;
	}

	/* --- icon swap: front icon exits down, twin drops in from above --- */
	.lp-block-icon {
		position: relative;
		height: 42px;
		margin-bottom: 10px;
	}

	.lp-block-icon .blicon {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin: 0 auto;
		font-size: 42px;
		line-height: 1;
		color: var(--color-teal);
		transition: 0.25s ease-out all;
	}

	.lp-block-icon .blicon :global(svg) {
		width: 42px;
		height: 42px;
	}

	.lp-block-icon .blicon + .blicon {
		opacity: 0;
		transform: translateY(-40px) scale(0.65);
	}

	.lp-block:hover .blicon {
		transform: translateY(40px) scale(0.65);
		opacity: 0;
	}

	.lp-block:hover .blicon + .blicon {
		transform: translateY(0) scale(1);
		opacity: 1;
	}

	/* --- title with a gold strip through the middle (light variant) --- */
	.lp-block-title {
		position: relative;
		z-index: 1;
		display: inline-block;
		margin: 1.5em auto;
		font-family: var(--font-body);
		font-size: 1.05em;
		line-height: 1.4;
		font-weight: 700;
		color: var(--color-heading);
	}

	.lp-block-title a {
		color: inherit;
		text-decoration: none;
	}

	.lp-block-title::after {
		content: "";
		position: absolute;
		z-index: -1;
		width: 102%;
		height: 1em;
		left: -1%;
		top: 50%;
		opacity: 0.4;
		transform: translateY(-50%);
		background-color: var(--color-gold);
	}

	.lp-block-text {
		width: 100%;
		font-size: 1em;
		line-height: 1.8;
		color: var(--color-text);
	}

	/* --- dark variant (lp-blocks2) --- */
	.lp-blocks-dark .lp-blocks-inside {
		/* Demo blocks have 4% column and ~7% combined row margins */
		gap: 4.5em 4%;
		max-width: var(--wide-width);
		padding: 2em 1em 5em;
		background: transparent;
	}

	.lp-blocks-dark .lp-block {
		overflow: visible;
		margin-top: 1.5em;
		padding: 0 0 3em;
		text-align: left;
	}

	/* Demo .lp-blocks2 .lp-block-icon: the teal tile is the WRAPPER
	   (68px: 30px glyph + 1.2em padding at 1rem); only the white glyph
	   swaps horizontally inside it — the tile itself never moves */
	.lp-blocks-dark .lp-block-icon {
		float: left;
		height: auto;
		width: auto;
		margin: -1.5em 0 0 2.5em;
		background: var(--color-teal-solid);
	}

	.lp-blocks-dark .lp-block-icon .blicon {
		position: relative;
		font-size: 1rem;
		padding: 1.2em;
		background: transparent;
		color: #ffffff;
	}

	.lp-blocks-dark .lp-block-icon .blicon :global(svg) {
		width: 30px;
		height: 30px;
	}

	.lp-blocks-dark .lp-block-icon .blicon + .blicon {
		position: absolute;
		inset: 0;
		opacity: 0;
		transform: translateX(-40px) scale(0.65);
	}

	.lp-blocks-dark .lp-block:hover .blicon {
		transform: translateX(40px) scale(0.65);
		opacity: 0;
	}

	.lp-blocks-dark .lp-block:hover .blicon + .blicon {
		transform: translateX(0) scale(1);
		opacity: 1;
	}

	.lp-blocks-dark .lp-block-content {
		clear: both;
		padding: 1em 2.5em 0;
	}

	.lp-blocks-dark .lp-block-title {
		margin: 1em 0 0.6em;
		font-family: var(--font-heading);
		font-size: 1.2em;
		font-weight: 700;
		color: var(--color-teal);
	}

	.lp-blocks-dark .lp-block-title::after {
		background: transparent;
	}

	.lp-blocks-dark :global(.ghost-header .ghost-title) {
		color: #ffffff;
	}

	@media (max-width: 900px) {
		.lp-blocks-inside {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.lp-blocks-inside {
			grid-template-columns: 1fr;
		}
	}
</style>
