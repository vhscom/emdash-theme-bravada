---
/**
 * bravada.hero — Bravada's landing-page static slider (.lp-slider /
 * .lp-staticslider): a full-bleed image under a gradient scrim, huge
 * Playfair caption whose letters periodically break up (a random
 * handful turn gold and swap out/in — cryoutSliderTitleBreakUp), a
 * light subtitle, a pair of buttons (outline-white / gold) that slide
 * in from the left, and a bouncing scroll chevron (.meta-arrow).
 *
 * `effect` selects the hero TEXT effect — the accent the animated
 * letters flash during the break-up — from Bravada Plus's four demo
 * personalities: bravada (gold), ripley (petrol), sculpt (plum),
 * sundown (red). Editable on the block in the admin.
 */
import MetaArrow from "../MetaArrow.astro";

interface HeroButton {
	label: string;
	url: string;
}

interface HeroNode {
	title?: string;
	subtitle?: string;
	/** Background image URL (media library file URL or external) */
	image?: string;
	imageAlt?: string;
	buttons?: HeroButton[];
	/** Animated-letter accent: bravada | ripley | sculpt | sundown */
	effect?: string;
}

// astro-portabletext hands custom type components the block as `node`
const { node } = Astro.props as { node: HeroNode };
const { title, subtitle, image, imageAlt = "", buttons = [] } = node;

const EFFECTS = ["bravada", "ripley", "sculpt", "sundown"];
const effect = EFFECTS.includes(node.effect ?? "") ? node.effect : "bravada";

// Local /images/demo/*.jpg assets ship pre-built AVIF/WebP siblings
// (same basename) so the LCP hero can serve a modern format without
// runtime image processing.
const heroAvif = image?.startsWith("/images/") ? image.replace(/\.jpg$/, ".avif") : undefined;
const heroWebp = image?.startsWith("/images/") ? image.replace(/\.jpg$/, ".webp") : undefined;
---

<section class="lp-slider full-bleed" data-effect={effect}>
	<div class="lp-staticslider">
		{
			image && heroAvif && heroWebp ? (
				<picture>
					<source srcset={heroAvif} type="image/avif" />
					<source srcset={heroWebp} type="image/webp" />
					<img
						class="lp-staticslider-image"
						src={image}
						alt={imageAlt}
						loading="eager"
						fetchpriority="high"
					/>
				</picture>
			) : (
				image && (
					<img
						class="lp-staticslider-image"
						src={image}
						alt={imageAlt}
						loading="eager"
						fetchpriority="high"
					/>
				)
			)
		}
		<div class="staticslider-caption">
			<div class="staticslider-caption-inside">
				{title && <h2 class="staticslider-caption-title breakup-title">{title}</h2>}
				{subtitle && <div class="staticslider-caption-text">{subtitle}</div>}
				{
					buttons.length > 0 && (
						<div class="staticslider-caption-buttons">
							{buttons.map((b, i) => (
								<a
									class={i % 2 === 0 ? "btn-outline-white" : "btn-gold"}
									href={b.url}
								>
									{b.label}
								</a>
							))}
						</div>
					)
				}
			</div>
		</div>
		<MetaArrow targetId="lp-after-slider" />
	</div>
</section>
<span id="lp-after-slider" class="after-hero-anchor"></span>

<script>
	import { initTitleBreakup } from "../../utils/breakup-client";

	// Bravada letter break-up on the slider caption (shared util; the
	// letter CSS lives in theme.css under .breakup-title)
	initTitleBreakup(".staticslider-caption-title");

</script>

<style>
	.lp-slider {
		background-color: var(--tint-slider);
	}

	.lp-staticslider {
		position: relative;
		overflow: hidden;
		text-align: center;
	}

	/* Fullscreen slider (bravada-fullscreen-headerimage): the theme
	   sizes the image to 100vh, which iOS resolves as the LARGE
	   viewport — lvh matches that on browsers that shrink vh */
	.lp-staticslider-image {
		display: block;
		width: 100%;
		height: 100vh;
		height: 100lvh;
		min-height: 480px;
		object-fit: cover;
		vertical-align: middle;
	}

	/* Bravada's overlay scrim: #08415c → #1c110a at 0.6 */
	.lp-staticslider::after {
		content: "";
		position: absolute;
		z-index: 2;
		inset: 0;
		background: linear-gradient(180deg, #08415c 0%, #1c110a 100%);
		opacity: 0.6;
		pointer-events: none;
	}

	/* Text-effect variants: the color the break-up letters flash
	   (measured from each personality's customizer CSS) */
	[data-effect="bravada"] {
		--letter-accent: #e9b44c;
	}

	[data-effect="ripley"] {
		--letter-accent: #227c9d;
	}

	[data-effect="sculpt"] {
		--letter-accent: #332142;
	}

	[data-effect="sundown"] {
		--letter-accent: #bf211e;
	}

	.staticslider-caption {
		position: absolute;
		z-index: 3;
		inset: 0;
		display: flex;
		flex-flow: column;
		justify-content: center;
		width: 100%;
		margin: 0 auto;
		/* Theme .staticslider-caption: centred in the FULL slider box
		   (padding 0; the fixed header floats over the image) */
		padding: 0 2.5em;
		color: #ffffff;
	}

	/* Demo: the caption itself caps at 85% above 1024px (was unbounded
	   here, making the desktop hero column wider than the original). */
	@media (min-width: 1025px) {
		.staticslider-caption {
			max-width: 85%;
		}
	}

	/* Demo breakpoints: padding tapers at 1152px/640px so the caption
	   keeps proportionally more width as the viewport narrows. */
	@media (max-width: 1152px) {
		.staticslider-caption {
			padding: 0 2em;
		}
	}

	@media (max-width: 640px) {
		.staticslider-caption {
			padding: 0 1em;
		}
	}

	.staticslider-caption-inside {
		/* Demo: 90% down to 900px, then 100% (no side inset) below
		   that — was flat 85% here, which double-narrowed the lede
		   together with .staticslider-caption-text's own 80%. */
		max-width: 90%;
		margin: 0 auto;
		text-align: center;
	}

	@media (max-width: 900px) {
		.staticslider-caption-inside {
			max-width: 100%;
		}
	}

	.staticslider-caption-title {
		margin: 0 0 0.1em;
		font-family: var(--font-heading);
		font-size: clamp(2.5em, 5vw, 5em);
		line-height: 1.3;
		font-weight: 700;
		color: #ffffff;
		opacity: 0;
		animation: 0.5s 0.25s slide-right ease-out forwards;
	}

	.staticslider-caption-text {
		max-width: 80%;
		margin: 3em auto;
		font-size: 1.2em;
		line-height: 1.5;
		font-weight: 300;
		letter-spacing: 1px;
		opacity: 0;
		animation: 0.5s 0.5s slide-right ease-out forwards;
	}

	.staticslider-caption-buttons {
		display: flex;
		justify-content: center;
		align-items: stretch;
		flex-wrap: wrap;
		gap: 0.9em 1.5em;
		margin: 3em auto;
		opacity: 0;
		animation: 0.5s 0.75s slide-right ease-out forwards;
	}

	@keyframes slide-right {
		from {
			opacity: 0;
			transform: translateX(-40px);
		}

		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.staticslider-caption-title,
		.staticslider-caption-text,
		.staticslider-caption-buttons {
			animation: none;
			opacity: 1;
		}

	}

	@media (max-width: 800px) {
		.staticslider-caption {
			font-size: 0.8em;
		}

		.staticslider-caption-text,
		.staticslider-caption-buttons {
			margin: 2em auto;
		}
	}

	/* Demo: buttons only stack and stretch full-width below 480px
	   (a.staticslider-button { width: 100% } at max-width: 480px);
	   above that they stay side-by-side at their intrinsic width. The
	   demo's stacked buttons aren't edge-to-edge either — its
	   display: table wrapper (no explicit width rule) resolves to
	   ~80% of .staticslider-caption-inside, same measure as the lede.
	   Cap the wrapper here rather than the flex default of filling it. */
	@media (max-width: 480px) {
		.staticslider-caption-buttons {
			flex-direction: column;
			align-items: stretch;
			max-width: 80%;
			margin-left: auto;
			margin-right: auto;
		}
	}
</style>
