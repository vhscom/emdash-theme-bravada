---
/**
 * bravada.hero — Bravada's landing-page static slider (.lp-slider /
 * .lp-staticslider): a full-bleed image under a gradient scrim, huge
 * Playfair caption whose letters periodically break up (a random
 * handful turn gold and swap out/in — cryoutSliderTitleBreakUp), a
 * light subtitle, a pair of buttons (outline-white / gold) that slide
 * in from the left, and a bouncing scroll chevron (.meta-arrow).
 *
 * `effect` selects the hero TEXT effect — the accent the animated
 * letters flash during the break-up — from Bravada Plus's four demo
 * personalities: bravada (gold), ripley (petrol), sculpt (plum),
 * sundown (red). Editable on the block in the admin.
 */
interface HeroButton {
	label: string;
	url: string;
}

interface HeroNode {
	title?: string;
	subtitle?: string;
	/** Background image URL (media library file URL or external) */
	image?: string;
	imageAlt?: string;
	buttons?: HeroButton[];
	/** Animated-letter accent: bravada | ripley | sculpt | sundown */
	effect?: string;
}

// astro-portabletext hands custom type components the block as `node`
const { node } = Astro.props as { node: HeroNode };
const { title, subtitle, image, imageAlt = "", buttons = [] } = node;

const EFFECTS = ["bravada", "ripley", "sculpt", "sundown"];
const effect = EFFECTS.includes(node.effect ?? "") ? node.effect : "bravada";
---

<section class="lp-slider full-bleed" data-effect={effect}>
	<div class="lp-staticslider">
		{image && <img class="lp-staticslider-image" src={image} alt={imageAlt} />}
		<div class="staticslider-caption">
			<div class="staticslider-caption-inside">
				{title && <h2 class="staticslider-caption-title breakup-title">{title}</h2>}
				{subtitle && <div class="staticslider-caption-text">{subtitle}</div>}
				{
					buttons.length > 0 && (
						<div class="staticslider-caption-buttons">
							{buttons.map((b, i) => (
								<a
									class={i % 2 === 0 ? "btn-outline-white" : "btn-gold"}
									href={b.url}
								>
									{b.label}
								</a>
							))}
						</div>
					)
				}
			</div>
		</div>
		<a href="#lp-after-slider" class="meta-arrow" aria-label="Scroll to content">
			<svg
				width="26"
				height="26"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg
			>
		</a>
	</div>
</section>
<span id="lp-after-slider"></span>

<script>
	import { initTitleBreakup } from "../../utils/breakup-client";

	// Bravada letter break-up on the slider caption (shared util; the
	// letter CSS lives in theme.css under .breakup-title)
	initTitleBreakup(".staticslider-caption-title");

	// Chevron scrolls smoothly to whatever follows the slider
	for (const arrow of document.querySelectorAll<HTMLAnchorElement>(
		".lp-slider .meta-arrow"
	)) {
		arrow.addEventListener("click", (e) => {
			const slider = arrow.closest(".lp-slider");
			const next = slider?.nextElementSibling;
			if (next) {
				e.preventDefault();
				next.scrollIntoView({ behavior: "smooth" });
			}
		});
	}
</script>

<style>
	.lp-slider {
		background-color: var(--tint-slider);
	}

	.lp-staticslider {
		position: relative;
		overflow: hidden;
		text-align: center;
	}

	/* Fullscreen slider (bravada-fullscreen-headerimage): the image
	   fills the whole viewport; svh keeps mobile URL bars honest */
	.lp-staticslider-image {
		display: block;
		width: 100%;
		height: 100vh;
		height: 100svh;
		min-height: 480px;
		object-fit: cover;
		vertical-align: middle;
	}

	/* Bravada's overlay scrim: #08415c → #1c110a at 0.6 */
	.lp-staticslider::after {
		content: "";
		position: absolute;
		z-index: 2;
		inset: 0;
		background: linear-gradient(180deg, #08415c 0%, #1c110a 100%);
		opacity: 0.6;
		pointer-events: none;
	}

	/* Text-effect variants: the color the break-up letters flash
	   (measured from each personality's customizer CSS) */
	[data-effect="bravada"] {
		--letter-accent: #e9b44c;
	}

	[data-effect="ripley"] {
		--letter-accent: #227c9d;
	}

	[data-effect="sculpt"] {
		--letter-accent: #332142;
	}

	[data-effect="sundown"] {
		--letter-accent: #bf211e;
	}

	.staticslider-caption {
		position: absolute;
		z-index: 3;
		inset: 0;
		display: flex;
		flex-flow: column;
		justify-content: center;
		width: 100%;
		margin: 0 auto;
		padding: 85px 2.5em 0;
		color: #ffffff;
	}

	.staticslider-caption-inside {
		max-width: 85%;
		margin: 0 auto;
		text-align: center;
	}

	.staticslider-caption-title {
		margin: 0 0 0.1em;
		font-family: var(--font-heading);
		font-size: clamp(2.5em, 5vw, 5em);
		line-height: 1.3;
		font-weight: 700;
		color: #ffffff;
		opacity: 0;
		animation: 0.5s 0.25s slide-right ease-out forwards;
	}

	.staticslider-caption-text {
		max-width: 80%;
		margin: 3em auto;
		font-size: 1.2em;
		line-height: 1.5;
		font-weight: 300;
		letter-spacing: 1px;
		opacity: 0;
		animation: 0.5s 0.5s slide-right ease-out forwards;
	}

	.staticslider-caption-buttons {
		display: flex;
		justify-content: center;
		align-items: stretch;
		flex-wrap: wrap;
		gap: 0.9em 1.5em;
		margin: 3em auto;
		opacity: 0;
		animation: 0.5s 0.75s slide-right ease-out forwards;
	}

	@keyframes slide-right {
		from {
			opacity: 0;
			transform: translateX(-40px);
		}

		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	/* Bouncing scroll chevron (.meta-arrow, 2.2s ease-out infinite) */
	.meta-arrow {
		position: absolute;
		z-index: 15;
		left: 0;
		right: 0;
		bottom: 50px;
		width: 100px;
		height: 40px;
		margin: 0 auto;
		text-align: center;
		color: #ffffff;
	}

	.meta-arrow:hover {
		color: var(--color-gold);
	}

	.meta-arrow svg {
		animation: meta-arrow 2.2s ease-out infinite;
	}

	@keyframes meta-arrow {
		60%,
		100% {
			opacity: 0;
			transform: translateY(20px);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.staticslider-caption-title,
		.staticslider-caption-text,
		.staticslider-caption-buttons {
			animation: none;
			opacity: 1;
		}

		.meta-arrow svg {
			animation: none;
		}
	}

	@media (max-width: 800px) {
		.staticslider-caption {
			font-size: 0.8em;
		}

		.staticslider-caption-text,
		.staticslider-caption-buttons {
			margin: 2em auto;
		}

		.meta-arrow {
			bottom: 20px;
		}
	}
</style>
