---
/**
 * bravada.products — the demo sidebar's WooCommerce-style product
 * list ("Top rated products" / "Recent reviews"): teal title link,
 * five-star teal rating, price or reviewer line, small framed thumb
 * on the right. Items are plain block data, editable in the admin.
 */
interface ProductItem {
	title: string;
	image?: string;
	url?: string;
	/** e.g. "£35.00" */
	price?: string;
	/** e.g. "by Ryan" */
	by?: string;
	/** 0–5 stars */
	rating?: number;
}

interface ProductsNode {
	items?: ProductItem[];
}

import StarRating from "../StarRating.astro";

const { node } = Astro.props as { node: ProductsNode };
const { items = [] } = node;
---

<ul class="bravada-products">
	{
		items.map((item) => (
			<li>
				<div class="product-info">
					<a href={item.url ?? "#"} class="product-title">
						{item.title}
					</a>
					{typeof item.rating === "number" && (
						<StarRating value={item.rating} size="0.8em" />
					)}
					{item.price && <span class="product-price">{item.price}</span>}
					{item.by && <span class="product-by">{item.by}</span>}
				</div>
				{item.image && (
					<a href={item.url ?? "#"} class="product-thumb" tabindex="-1">
						<img src={item.image} alt={item.title} loading="lazy" />
					</a>
				)}
			</li>
		))
	}
</ul>

<style>
	.bravada-products {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.bravada-products li {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1em;
		padding: 0.9em 0;
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.bravada-products li:last-child {
		border-bottom: none;
	}

	.product-info {
		display: flex;
		flex-direction: column;
		gap: 0.25em;
		min-width: 0;
	}

	.product-title {
		color: var(--color-teal);
		text-decoration: none;
		font-size: 1.05em;
		transition: color 0.2s ease-out;
	}

	.product-title:hover {
		color: var(--color-gold);
	}

	.product-price,
	.product-by {
		font-size: 0.95em;
		color: var(--color-text);
	}

	/* Demo product thumbs: 4px white frame */
	.product-thumb {
		flex-shrink: 0;
		line-height: 0;
		border: 4px solid var(--color-surface);
		box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
	}

	.product-thumb img {
		width: 58px;
		height: 58px;
		object-fit: cover;
	}
</style>
