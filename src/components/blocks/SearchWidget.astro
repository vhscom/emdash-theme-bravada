---
/**
 * bravada.search — the demo sidebar search: white input with a solid
 * gold submit block. Submits to the site search page.
 */
interface SearchNode {
	placeholder?: string;
}

const { node } = Astro.props as { node: SearchNode };
const placeholder = node.placeholder ?? "Search";
---

<form role="search" method="get" action="/search" class="bravada-search">
	<label>
		<span class="sr-only">Search for:</span>
		<input type="search" name="q" placeholder={placeholder} autocomplete="off" />
	</label>
	<button type="submit" aria-label="Search">
		<svg
			width="16"
			height="16"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2.5"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
			><circle cx="11" cy="11" r="8"></circle><line
				x1="21"
				y1="21"
				x2="16.65"
				y2="16.65"></line></svg
		>
	</button>
</form>

<style>
	.bravada-search {
		display: flex;
		gap: 0;
		background: var(--color-surface);
		/* Demo .searchform shadow */
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
	}

	.bravada-search label {
		flex: 1;
		min-width: 0;
	}

	.bravada-search input[type="search"] {
		width: 100%;
		padding: 0.85em 1em;
		border: 1px solid var(--color-border);
		border-right: 0;
		border-radius: 0;
		background: var(--color-surface);
		font-family: var(--font-body);
		font-size: var(--font-size-sm);
		color: var(--color-text);
	}

	.bravada-search input[type="search"]:focus {
		outline: none;
		border-color: var(--color-gold);
	}

	.bravada-search button {
		padding: 0 1.1em;
		border: none;
		background: var(--color-gold);
		color: #ffffff;
		cursor: pointer;
		transition: background 0.2s ease-out;
	}

	.bravada-search button:hover {
		background: var(--color-teal-solid);
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
