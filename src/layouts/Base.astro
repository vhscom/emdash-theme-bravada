---
import { getMenu, getEmDashCollection, getSiteSettings } from "emdash";
import {
	WidgetArea,
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import { Font } from "astro:assets";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import "../styles/tokens.css";
import "../styles/theme.css";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	/** Pass content reference for plugin page contributions on content pages */
	content?: { collection: string; id: string; slug?: string | null };
	/** Bravada over-menu: transparent header floating over a hero */
	overHero?: boolean;
}

const {
	title,
	pageTitle,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
	overHero = false,
} = Astro.props;
const { siteTitle, siteTagline, siteLogo } = resolveBlogSiteIdentity(await getSiteSettings());
// If title already includes site title (from getSeoMeta), use as-is
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;

// Fetch primary menu defined in seed
const menu = await getMenu("primary");

// Optional "social" menu. If a site defines a `social` menu in its seed,
// it'll render in the footer's "Connect" column. Otherwise that column
// just shows RSS, avoiding duplication with the "Navigate" column above.
const socialMenu = await getMenu("social");

// Fetch pages for footer
const { entries: pages } = await getEmDashCollection("pages");

// Build public page context for plugin contributions
// SEO data is passed here and rendered securely by EmDashHead
const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

// Check if user is logged in (for showing admin link)
const isLoggedIn = !!Astro.locals.user;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<Font cssVariable="--font-body" preload />
		<Font cssVariable="--font-display" preload />
		<Font cssVariable="--font-mono" />
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
		<script is:inline>
			// Gate the .aos reveal-hiding on JS actually running, so no-JS
			// visitors see all landing-page content.
			document.documentElement.classList.add("js");
		</script>
		<script is:inline>
			// Apply an explicit theme choice immediately to prevent flash.
			// With no cookie, color-scheme: light dark follows the OS.
			(function () {
				var c = document.cookie;
				var i = c.indexOf("theme=");
				var theme = i >= 0 ? c.slice(i + 6).split(";")[0] : null;
				if (theme === "dark" || theme === "light") {
					document.documentElement.classList.add(theme);
				}
			})();
		</script>
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />
		<header class:list={["site-header", { "over-hero": overHero }]}>
			<nav class="nav">
				<a href="/" class="site-title">
					{siteLogo
						? <img src={siteLogo.url} alt={siteLogo.alt || siteTitle} class="site-logo-img" />
						: siteTitle
					}
				</a>
				<div class="nav-right">
					<ul class="nav-links">
						{
							menu?.items.map((item) => (
								<li class:list={["menu-item", { "has-children": item.children.length > 0 }]}>
									<a href={item.url} target={item.target}>
										<span>{item.label}</span>
									</a>
									{item.children.length > 0 && (
										<ul class="sub-menu">
											{item.children.map((child) => (
												<li>
													<a href={child.url} target={child.target}>
														<span>{child.label}</span>
													</a>
												</li>
											))}
										</ul>
									)}
								</li>
							))
						}
						<li class="menu-item menu-main-search">
							<button
								type="button"
								class="search-toggle"
								aria-label="Search"
								aria-expanded="false"
								aria-controls="menu-search-overlay"
							>
								<svg
									width="17"
									height="17"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2.5"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true"
									><circle cx="11" cy="11" r="8"></circle><line
										x1="21"
										y1="21"
										x2="16.65"
										y2="16.65"></line></svg
								>
							</button>
						</li>
					</ul>
				</div>
				{
					isLoggedIn && (
						<a href="/_emdash/admin" class="nav-admin">
							Admin
						</a>
					)
				}
			</nav>
		</header>

		<!-- Bravada menu-search-animated: fullscreen dark layer with a
		     centered pill input that slides up; live results below it -->
		<div
			id="menu-search-overlay"
			class="menu-search-overlay"
			hidden
			role="dialog"
			aria-modal="true"
			aria-label="Search"
		>
			<button type="button" class="search-cancel" aria-label="Close search">
				<svg
					width="28"
					height="28"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					aria-hidden="true"
					><line x1="18" y1="6" x2="6" y2="18"></line><line
						x1="6"
						y1="6"
						x2="18"
						y2="18"></line></svg
				>
			</button>
			<div class="search-shell">
				<LiveSearch
					placeholder="Search…"
					class="site-search"
					inputClass="site-search-input"
					resultsClass="site-search-results"
					resultClass="site-search-result"
					collections={["posts", "pages"]}
				/>
			</div>
		</div>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-inner">
				<div class="footer-widgets-section">
					<WidgetArea name="footer" />
				</div>
				<div class="footer-bottom">
					<nav class="footer-socials" aria-label="Social links">
						{
							socialMenu?.items.map((item) => (
								<a
									href={item.url}
									target={item.target}
									rel={
										item.target === "_blank"
											? "noopener noreferrer"
											: undefined
									}
								>
									{item.label}
								</a>
							))
						}
					</nav>
					<p class="footer-copyright">
						©{new Date().getFullYear()} {siteTitle} — {siteTagline}
						· Powered by <a href="https://emdashcms.com">EmDash</a>
					</p>
					<nav class="footermenu" aria-label="Footer">
						<a href="/">Home</a>
						<span class="sep">/</span>
						<a href="/posts">Blog</a>
						<span class="sep">/</span>
						{
							pages
								.filter((page) => (page.data.slug || page.id) !== "home")
								.slice(0, 2)
								.map((page) => (
									<>
										<a href={`/pages/${page.data.slug || page.id}`}>
											{page.data.title}
										</a>
										<span class="sep">/</span>
									</>
								))
						}
						<a href="/rss.xml">RSS</a>
					</nav>
					<div class="theme-switcher">
						<button
							type="button"
							class="theme-btn"
							data-theme="light"
							aria-label="Light mode"
						>
							<svg
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><circle cx="12" cy="12" r="5"></circle><line
									x1="12"
									y1="1"
									x2="12"
									y2="3"></line><line x1="12" y1="21" x2="12" y2="23"
								></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"
								></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
								></line><line x1="1" y1="12" x2="3" y2="12"></line><line
									x1="21"
									y1="12"
									x2="23"
									y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"
								></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"
								></line></svg
							>
						</button>
						<button
							type="button"
							class="theme-btn"
							data-theme="dark"
							aria-label="Dark mode"
						>
							<svg
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
								></path></svg
							>
						</button>
						<button
							type="button"
							class="theme-btn"
							data-theme="system"
							aria-label="System theme"
						>
							<svg
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><rect x="2" y="3" width="20" height="14" rx="2" ry="2"
								></rect><line x1="8" y1="21" x2="16" y2="21"></line><line
									x1="12"
									y1="17"
									x2="12"
									y2="21"></line></svg
							>
						</button>
					</div>
				</div>
			</div>
		</footer>

		<script>
			// Theme switcher
			const THEME_REGEX = /theme=([^;]+)/;
			const themeBtns =
				document.querySelectorAll<HTMLButtonElement>(".theme-btn");
			const root = document.documentElement;

			function setCookie(
				name: string,
				value: string,
				maxAge: number = 31536000
			) {
				const secure = location.protocol === "https:" ? "; Secure" : "";
				if (value === "") {
					document.cookie = `${name}=; path=/; max-age=0; SameSite=Lax${secure}`;
				} else {
					document.cookie = `${name}=${value}; path=/; max-age=${maxAge}; SameSite=Lax${secure}`;
				}
			}

			function setTheme(theme: string) {
				if (theme === "system") {
					setCookie("theme", "");
					root.classList.remove("light", "dark");
				} else {
					setCookie("theme", theme);
					root.classList.remove("light", "dark");
					root.classList.add(theme);
				}
				updateActiveBtn(theme);
			}

			function updateActiveBtn(theme: string) {
				themeBtns.forEach((btn) => {
					btn.classList.toggle("active", btn.dataset.theme === theme);
				});
			}

			function getStoredTheme(): string {
				const match = document.cookie.match(THEME_REGEX);
				return match ? match[1] : "system";
			}

			// Initialize
			const storedTheme = getStoredTheme();
			setTheme(storedTheme);

			themeBtns.forEach((btn) => {
				btn.addEventListener("click", () => {
					setTheme(btn.dataset.theme || "system");
				});
			});
		</script>

		<style is:global>
			/*
			 * Establish layer order: "base" has lower priority than unlayered
			 * styles, so theme.css overrides always win regardless of source
			 * order in the bundled CSS.
			 */
			@layer base;

			@layer base {
				*:where(:not([class*="emdash"]):not([class*="ec-"])),
				*:where(:not([class*="emdash"]):not([class*="ec-"]))::before,
				*:where(:not([class*="emdash"]):not([class*="ec-"]))::after {
					box-sizing: border-box;
				}

				body,
				h1,
				h2,
				h3,
				h4,
				h5,
				h6,
				p,
				ul,
				ol,
				figure,
				blockquote,
				dl,
				dd {
					margin: 0;
				}

				ul,
				ol {
					padding: 0;
				}

				/*
				 * Design tokens live in src/styles/tokens.css. Colors are
				 * defined with light-dark(); these rules pin the scheme when
				 * the footer switcher sets an explicit choice. With no class,
				 * color-scheme: light dark follows the OS preference. The
				 * @supports guard keeps the toggle from forcing dark UA form
				 * controls on browsers stuck on the plain-light fallback.
				 */
				@supports (color: light-dark(#000, #fff)) {
					:root.light {
						color-scheme: light;
					}

					:root.dark {
						color-scheme: dark;
					}
				}

				html {
					scroll-behavior: smooth;
				}

				body {
					font-family: var(--font-body);
					font-size: var(--font-size-base);
					line-height: var(--leading-relaxed);
					color: var(--color-text);
					background: var(--color-bg);
					-webkit-font-smoothing: antialiased;
					-moz-osx-font-smoothing: grayscale;
					min-height: 100vh;
				}

				a:where(:not([class*="emdash"]):not([class*="ec-"])) {
					color: var(--color-brand);
					text-decoration: none;
					transition: color var(--transition-fast);
				}

				a:where(:not([class*="emdash"]):not([class*="ec-"])):hover {
					color: var(--color-brand-hover);
				}

				img {
					max-width: 100%;
					height: auto;
					display: block;
				}

				h1,
				h2,
				h3,
				h4,
				h5,
				h6 {
					font-family: var(--font-heading);
					line-height: var(--leading-tight);
					font-weight: var(--font-weight-heading);
					letter-spacing: var(--tracking-snug);
				}

				h1 {
					font-weight: var(--font-weight-display);
					letter-spacing: var(--tracking-tight);
				}

				::selection {
					background: var(--color-brand);
					color: var(--color-on-brand);
				}
			}
		</style>

		<style>
			/* Bravada fixed menu: 75px bar pinned to the top. Solid white
			   normally; transparent when floating over a hero until the
			   page scrolls (.header-fixed added by script). */
			.site-header {
				position: sticky;
				top: 0;
				z-index: 100;
				background: var(--color-surface);
				box-shadow: 0 1px 0 var(--color-border-subtle);
				transition:
					background 0.3s ease,
					box-shadow 0.3s ease;
			}

			.site-header.over-hero {
				position: fixed;
				left: 0;
				right: 0;
				box-shadow: none;
			}

			.site-header.over-hero.header-fixed {
				background: var(--color-surface);
				box-shadow: 0 1px 0 var(--color-border-subtle);
			}

			.nav {
				display: flex;
				justify-content: space-between;
				align-items: center;
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: var(--spacing-4) var(--spacing-6);
				height: var(--nav-height);
			}

			.site-title {
				font-size: var(--font-size-lg);
				font-weight: 600;
				color: var(--color-text);
				text-decoration: none;
				letter-spacing: var(--tracking-snug);
			}

			.site-title:hover {
				color: var(--color-brand);
			}

			.site-logo-img {
				height: 48px;
				width: auto;
				display: block;
				margin: -8px 0;
			}

			.nav-right {
				display: flex;
				align-items: center;
				gap: var(--spacing-6);
				margin-inline-start: auto;
			}

			.nav-links {
				display: flex;
				gap: var(--spacing-8);
				margin: 0;
				padding: 0;
				list-style: none;
				font-size: var(--font-size-base);
			}

			.nav-links .menu-item {
				position: relative;
			}

			.nav-links a {
				text-decoration: none;
				color: var(--color-text);
				transition: color var(--transition-fast);
			}

			.nav-links a:hover {
				color: var(--color-brand);
			}

			.nav-links .menu-item > a {
				display: inline-block;
				line-height: var(--nav-height);
			}

			/* Dropdowns: Bravada's dark teal submenu panel. It slides DOWN
			   into place from -25px (demo: #access ul ul) with a soft
			   drop shadow; item labels get a translucent white wash on
			   hover (.sub-menu li a:hover span). */
			.nav-links .sub-menu {
				position: absolute;
				top: 100%;
				left: -1em;
				z-index: 200;
				min-width: 200px;
				margin: 0;
				padding: 0.4em 0;
				list-style: none;
				background: var(--color-submenu-bg);
				box-shadow: 10px 10px 20px rgba(0, 0, 0, 0.05);
				opacity: 0;
				visibility: hidden;
				transform: translateY(-25px);
				transition: 0.2s all ease-in;
			}

			.nav-links .menu-item:hover > .sub-menu,
			.nav-links .menu-item:focus-within > .sub-menu {
				opacity: 1;
				visibility: visible;
				transform: translateY(0);
			}

			.nav-links .sub-menu a {
				display: block;
				padding: 0;
				color: #ffffff !important;
				font-size: var(--font-size-sm);
			}

			.nav-links .sub-menu a span {
				display: block;
				padding: 0.35em 1.5em;
				transition: 0.2s ease-out all;
			}

			.nav-links .sub-menu a:hover span,
			.nav-links .sub-menu a:focus-visible span {
				background: rgba(255, 255, 255, 0.1);
			}

			/* Search icon in the menu (Bravada menu-main-search) */
			.menu-main-search .search-toggle {
				display: flex;
				align-items: center;
				height: var(--nav-height);
				padding: 0 0.2em;
				border: none;
				background: none;
				color: var(--color-menu-link);
				cursor: pointer;
				transition: color 0.2s ease-out;
			}

			.menu-main-search .search-toggle:hover {
				color: var(--color-brand);
			}

			.menu-main-search .search-toggle:focus-visible,
			.search-cancel:focus-visible {
				outline: 2px solid var(--color-teal);
				outline-offset: 2px;
			}

			.menu-main-search .search-toggle:focus:not(:focus-visible) {
				outline: none;
			}

			.site-header.over-hero:not(.header-fixed)
				.menu-main-search
				.search-toggle {
				color: #ffffff;
			}

			.nav-admin {
				font-size: var(--font-size-sm);
				color: var(--color-text-secondary);
				text-decoration: none;
				transition: color var(--transition-fast);
			}

			.nav-admin:hover {
				color: var(--color-text);
			}

			/* Fullscreen menu search (Bravada #access .menu-search-animated):
			   dark layer, white pill input sliding up from +150px */
			.menu-search-overlay {
				position: fixed;
				inset: 0;
				z-index: 1000;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				padding: 1em;
				background: rgba(0, 0, 0, 0.8);
			}

			.menu-search-overlay[hidden] {
				display: none;
			}

			.search-cancel {
				position: absolute;
				top: 1em;
				right: 3em;
				display: flex;
				align-items: center;
				justify-content: center;
				width: 44px;
				height: 44px;
				border: none;
				background: none;
				color: rgba(255, 255, 255, 0.75);
				cursor: pointer;
				transition: color 0.2s ease-out;
			}

			.search-cancel:hover {
				color: #ffffff;
			}

			.search-shell {
				width: min(860px, 92vw);
			}

			.search-shell :global(.site-search) {
				position: relative;
				display: block;
				width: 100%;
				--emdash-search-border-focus: transparent;
			}

			:global(.site-search-input) {
				width: 100% !important;
				height: 3.5em !important;
				padding: 0 1.5em !important;
				border: 0 !important;
				border-radius: 100px !important;
				font-family: var(--font-body) !important;
				font-size: 1.5em !important;
				line-height: 2 !important;
				font-weight: 400;
				text-align: center;
				background: #ffffff !important;
				color: #555555 !important;
				box-shadow: 0 0 15px 15px rgba(0, 0, 0, 0.25);
				opacity: 0;
				transform: translateY(150px);
				transition: 0.25s ease-in-out all;
			}

			.menu-search-overlay.is-active :global(.site-search-input) {
				opacity: 1;
				transform: translateY(0);
			}

			:global(.site-search-input)::-webkit-search-cancel-button {
				-webkit-appearance: none;
				appearance: none;
			}

			:global(.site-search-input)::placeholder {
				color: #a7a7a7;
			}

			:global(.site-search-input):focus,
			:global(.site-search-input):focus-visible {
				outline: none;
				border: 0 !important;
			}

			:global(.site-search-results) {
				position: absolute;
				top: 100%;
				left: 0;
				right: 0;
				margin-top: var(--spacing-3);
				background: var(--color-surface);
				border: 1px solid var(--color-border);
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-lg);
				max-height: min(50vh, 400px);
				overflow-y: auto;
				z-index: 1000;
			}

			:global(.site-search-results .emdash-live-search-loading),
			:global(.site-search-results .emdash-live-search-no-results) {
				padding: var(--spacing-4);
				text-align: center;
				color: var(--color-muted);
				font-size: var(--font-size-sm);
			}

			:global(.site-search-result) {
				display: block;
				padding: var(--spacing-3) var(--spacing-4);
				text-decoration: none;
				color: var(--color-text);
				border-bottom: 1px solid var(--color-border-subtle);
				transition: background var(--transition-fast);
			}

			:global(.site-search-result):last-child {
				border-bottom: none;
			}

			:global(.site-search-result):hover,
			:global(.site-search-result):focus,
			:global(.site-search-result.focused) {
				background: var(--color-surface);
				outline: none;
			}

			:global(.site-search-result .emdash-live-search-result-title) {
				display: block;
				font-weight: 500;
				font-size: var(--font-size-sm);
			}

			:global(.site-search-result .emdash-live-search-result-collection) {
				display: block;
				font-size: var(--font-size-xs);
				color: var(--color-muted);
				text-transform: uppercase;
				letter-spacing: var(--tracking-wide);
				margin-top: 2px;
			}

			:global(.site-search-result .emdash-live-search-result-snippet) {
				display: block;
				font-size: var(--font-size-sm);
				color: var(--color-muted);
				margin-top: var(--spacing-1);
				line-height: var(--leading-snug);
			}

			:global(.site-search-result .emdash-live-search-result-snippet mark) {
				font-weight: 600;
				color: var(--color-text);
			}

			main {
				min-height: calc(100vh - var(--nav-height) - 300px);
			}

			/* Footer — Bravada #colophon/#footer: dark band, widget columns */
		.site-footer {
			background: var(--color-footer-bg);
			color: var(--color-footer-text);
		}

		.footer-inner {
			max-width: var(--wide-width);
			margin: 0 auto;
			padding: var(--spacing-12) var(--spacing-8) var(--spacing-8);
		}

		/* Three widget columns (footer-three) */
		.footer-widgets-section :global(.widget-area) {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: var(--spacing-12);
			margin-bottom: var(--spacing-12);
		}

		.footer-widgets-section :global(.widget) {
			color: var(--color-footer-text);
			font-size: var(--font-size-sm);
			line-height: var(--leading-relaxed);
		}

		/* Widget titles: Playfair on the gold highlighter strip */
		.footer-widgets-section :global(.widget__title),
		.footer-widgets-section :global(.widget-title) {
			display: inline-block;
			margin-bottom: var(--spacing-4);
			font-family: var(--font-heading);
			font-size: 1.2em;
			font-weight: 700;
			line-height: 1.6;
			color: #ffffff;
			background-image: linear-gradient(
				to bottom,
				var(--gold-strip) 0%,
				var(--gold-strip) 100%
			);
			background-repeat: no-repeat;
			background-size: 100% 0.6em;
			background-position: 0 100%;
		}

		.footer-widgets-section :global(.widget__content) {
			color: var(--color-footer-text);
		}

		.footer-widgets-section :global(.widget a) {
			color: var(--color-footer-text);
		}

		.footer-widgets-section :global(.widget a:hover) {
			color: var(--color-gold);
		}

		.footer-widgets-section :global(.widget img) {
			max-width: 100%;
			height: auto;
		}

		.footer-widgets-section :global(.widget ul) {
			list-style: none;
			margin: 0;
			padding: 0;
		}

		.footer-widgets-section :global(.widget li) {
			padding: var(--spacing-1) 0;
			border-bottom: 1px solid rgba(255, 255, 255, 0.075);
		}

		.footer-bottom {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: var(--spacing-3);
			padding-top: var(--spacing-6);
			border-top: 1px solid rgba(255, 255, 255, 0.075);
			text-align: center;
		}

		.footer-socials {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: var(--spacing-5);
		}

		.footer-socials a {
			color: var(--color-footer-text);
			text-decoration: none;
			font-size: var(--font-size-sm);
			transition: color 0.2s;
		}

		.footer-socials a:hover {
			color: var(--color-gold);
		}

		.footer-copyright {
			font-size: var(--font-size-sm);
			color: var(--color-footer-muted);
		}

		.footer-copyright a {
			color: var(--color-footer-text);
		}

		.footermenu {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: var(--spacing-2);
			font-size: var(--font-size-sm);
		}

		.footermenu a {
			color: var(--color-footer-text);
			text-decoration: none;
		}

		.footermenu a:hover {
			color: var(--color-gold);
		}

		.footermenu .sep {
			color: var(--color-footer-muted);
		}

		/* Theme switcher */
			.theme-switcher {
				display: flex;
				gap: var(--spacing-1);
				padding: var(--spacing-1);
				background: var(--color-surface);
				border-radius: var(--radius);
			}

			.theme-btn {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 32px;
				height: 28px;
				background: transparent;
				border: none;
				color: var(--color-muted);
				border-radius: var(--radius);
				cursor: pointer;
				transition: all var(--transition-fast);
			}

			.theme-btn:hover {
				color: var(--color-text-secondary);
			}

			.theme-btn.active {
				background: var(--color-bg);
				color: var(--color-text);
				box-shadow: var(--shadow-sm);
			}

			.theme-btn svg {
				width: 16px;
				height: 16px;
			}

			@media (max-width: 900px) {
				.footer-grid {
					grid-template-columns: 1fr 1fr;
					gap: var(--spacing-8);
				}

				.footer-brand {
					grid-column: span 2;
					max-width: none;
				}
			}

			@media (max-width: 640px) {
				.site-header {
					position: relative;
					border-bottom: none;
				}

				.nav {
					display: grid;
					grid-template-columns: minmax(0, 1fr) auto;
					align-items: center;
					height: auto;
					column-gap: var(--spacing-3);
					row-gap: var(--spacing-2);
					padding: var(--spacing-3) var(--spacing-4);
				}

				.site-title {
					grid-column: 1;
					grid-row: 1;
					font-size: var(--font-size-base);
					min-width: 0;
				}

				.nav-right {
					grid-column: 1 / -1;
					grid-row: 2;
					display: grid;
					row-gap: var(--spacing-2);
				}

				:global(.site-search-input) {
					font-size: var(--font-size-lg) !important;
				}

				.search-cancel {
					right: 1em;
				}

				.nav-links {
					grid-column: 1;
					display: flex;
					column-gap: var(--spacing-3);
					row-gap: var(--spacing-1);
					flex-wrap: wrap;
					justify-content: flex-start;
				}

				.nav-admin {
					grid-column: 2;
					grid-row: 1;
					justify-self: end;
					font-size: var(--font-size-xs);
					margin-inline-start: 0;
					white-space: nowrap;
				}

				.footer-grid {
					grid-template-columns: 1fr;
				}

				.footer-brand {
					grid-column: span 1;
				}

				.footer-bottom {
					flex-direction: column;
					gap: var(--spacing-4);
					text-align: center;
				}

				.footer-controls {
					flex-wrap: wrap;
					justify-content: center;
				}
			}
		</style>

		<button id="toTop" aria-label="Back to top">
			<svg
				width="20"
				height="20"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg
			>
		</button>

		<script>
			// Bravada fixed-menu scroll state: the over-hero header turns
			// solid once the page scrolls past the top; the back-to-top
			// button fades in after a screenful.
			const header = document.querySelector(".site-header");
			const toTop = document.getElementById("toTop");

			function onScroll() {
				const y = window.scrollY;
				header?.classList.toggle("header-fixed", y > 30);
				toTop?.classList.toggle("visible", y > window.innerHeight);
			}

			onScroll();
			window.addEventListener("scroll", onScroll, { passive: true });

			toTop?.addEventListener("click", () => {
				window.scrollTo({ top: 0, behavior: "smooth" });
			});
		</script>

		<script>
			// Bravada on-scroll reveals: elements start with .aos + a
			// direction class (see theme.css); remove .aos when they enter
			// the viewport so the transition plays.
			const aosEls = document.querySelectorAll(".aos");
			if (aosEls.length > 0 && "IntersectionObserver" in window) {
				const io = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.remove("aos");
								io.unobserve(entry.target);
							}
						}
					},
					{ rootMargin: "0px 0px -10% 0px" }
				);
				aosEls.forEach((el) => io.observe(el));
			} else {
				aosEls.forEach((el) => el.classList.remove("aos"));
			}
		</script>

		<script>
			// Bravada animated menu search: the nav icon opens a fullscreen
			// dark layer; the pill input slides up once it's visible.
			// Esc, ✕, or a click on the backdrop closes it. ⌘K/Ctrl+K opens
			// it too.
			const overlay = document.getElementById("menu-search-overlay");
			const toggle = document.querySelector<HTMLButtonElement>(".search-toggle");
			const cancel = overlay?.querySelector<HTMLButtonElement>(".search-cancel");
			const input = overlay?.querySelector<HTMLInputElement>(".site-search-input");

			function openSearch() {
				if (!overlay) return;
				overlay.hidden = false;
				toggle?.setAttribute("aria-expanded", "true");
				// Two frames so the unhide commits before the slide-up plays
				requestAnimationFrame(() =>
					requestAnimationFrame(() => {
						overlay.classList.add("is-active");
						input?.focus();
					})
				);
			}

			function closeSearch() {
				if (!overlay || overlay.hidden) return;
				overlay.classList.remove("is-active");
				toggle?.setAttribute("aria-expanded", "false");
				setTimeout(() => {
					overlay.hidden = true;
				}, 250);
				toggle?.focus();
			}

			toggle?.addEventListener("click", openSearch);
			cancel?.addEventListener("click", closeSearch);
			overlay?.addEventListener("click", (e) => {
				if (e.target === overlay) closeSearch();
			});
			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape") closeSearch();
				if ((e.metaKey || e.ctrlKey) && e.key === "k") {
					e.preventDefault();
					overlay?.hidden ? openSearch() : input?.focus();
				}
			});
		</script>
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
