		</style>

		<button id="toTop" aria-label="Back to top">
			<svg
				width="20"
				height="20"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"><polyline points="18 15 12 9 6 15"></polyline></svg
			>
			<svg
				width="20"
				height="20"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"><polyline points="18 15 12 9 6 15"></polyline></svg
			>
		</button>

		<script>
			// Bravada fixed-menu scroll state: the over-hero header turns
			// solid once the page scrolls past the top; the back-to-top
			// button fades in after a screenful.
			const header = document.querySelector(".site-header");
			const toTop = document.getElementById("toTop");

			function onScroll() {
				const y = window.scrollY;
				header?.classList.toggle("header-fixed", y > 30);
				toTop?.classList.toggle("visible", y > window.innerHeight);
			}

			onScroll();
			window.addEventListener("scroll", onScroll, { passive: true });

			toTop?.addEventListener("click", () => {
				window.scrollTo({ top: 0, behavior: "smooth" });
			});
		</script>

		<script>
			// Bravada on-scroll reveals: elements start with .aos + a
			// direction class (see theme.css); remove .aos when they enter
			// the viewport so the transition plays.
			const aosEls = document.querySelectorAll(".aos");
			if (aosEls.length > 0 && "IntersectionObserver" in window) {
				const io = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.remove("aos");
								io.unobserve(entry.target);
							}
						}
					},
					{ rootMargin: "0px 0px -10% 0px" }
				);
				aosEls.forEach((el) => io.observe(el));
			} else {
				aosEls.forEach((el) => el.classList.remove("aos"));
			}
		</script>

		<script>
			// Bravada fullscreen burger menu (cryoutMobileMenuInit): fade the
			// teal layer in, drop items in with staggered delays, morph the
			// hamburger into an X, collapse submenus behind dropdown toggles.
			const burger = document.querySelector<HTMLButtonElement>(".hamburger");
			const mobileMenu = document.getElementById("mobile-menu");

			// Staggered entrance (demo: transition-delay = 0.03s * index)
			mobileMenu
				?.querySelectorAll<HTMLElement>("#mobile-nav > li")
				.forEach((li, i) => {
					li.style.transitionDelay = `${0.03 * i}s`;
				});

			function setBurger(open: boolean) {
				if (!mobileMenu) return;
				if (open) {
					mobileMenu.hidden = false;
					requestAnimationFrame(() =>
						requestAnimationFrame(() => {
							document.body.classList.add("burgermenu-active", "noscroll");
						})
					);
				} else {
					document.body.classList.remove("burgermenu-active", "noscroll");
					setTimeout(() => {
						mobileMenu.hidden = true;
					}, 500);
				}
				burger?.setAttribute("aria-expanded", String(open));
			}

			burger?.addEventListener("click", () =>
				setBurger(!document.body.classList.contains("burgermenu-active"))
			);
			document.addEventListener("keydown", (e) => {
				if (
					e.key === "Escape" &&
					document.body.classList.contains("burgermenu-active")
				) {
					setBurger(false);
					burger?.focus();
				}
			});
			// Close when a link is followed (anchors on the same page)
			mobileMenu?.querySelectorAll("a").forEach((a) => {
				a.addEventListener("click", () => setBurger(false));
			});

			// Submenu accordions
			mobileMenu
				?.querySelectorAll<HTMLButtonElement>(".dropdown-toggle")
				.forEach((btn) => {
					btn.addEventListener("click", () => {
						const li = btn.closest("li");
						const sub = li?.querySelector(".mobile-sub-menu");
						const link = li?.querySelector(":scope > a");
						const open = btn.classList.toggle("toggle-on");
						sub?.classList.toggle("toggled-on", open);
						link?.classList.toggle("toggled-on", open);
						btn.setAttribute("aria-expanded", String(open));
					});
				});
		</script>

		<script>
			// Bravada animated menu search: the nav icon opens a fullscreen
			// dark layer; the pill input slides up once it's visible.
			// Esc, ✕, or a click on the backdrop closes it. ⌘K/Ctrl+K opens
			// it too.
			const overlay = document.getElementById("menu-search-overlay");
			const toggle = document.querySelector<HTMLButtonElement>(".search-toggle");
			const cancel = overlay?.querySelector<HTMLButtonElement>(".search-cancel");
			const input = overlay?.querySelector<HTMLInputElement>(".site-search-input");

			function openSearch() {
				if (!overlay) return;
				overlay.hidden = false;
				toggle?.setAttribute("aria-expanded", "true");
				// Two frames so the unhide commits before the slide-up plays
				requestAnimationFrame(() =>
					requestAnimationFrame(() => {
						overlay.classList.add("is-active");
						input?.focus();
					})
				);
			}

			function closeSearch() {
				if (!overlay || overlay.hidden) return;
				overlay.classList.remove("is-active");
				toggle?.setAttribute("aria-expanded", "false");
				setTimeout(() => {
					overlay.hidden = true;
				}, 250);
				toggle?.focus();
			}

			toggle?.addEventListener("click", openSearch);
			cancel?.addEventListener("click", closeSearch);
			overlay?.addEventListener("click", (e) => {
				if (e.target === overlay) closeSearch();
			});
			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape") closeSearch();
				if ((e.metaKey || e.ctrlKey) && e.key === "k") {
					e.preventDefault();
					overlay?.hidden ? openSearch() : input?.focus();
				}
			});
		</script>
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
