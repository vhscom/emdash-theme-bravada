			.theme-btn svg {
				width: 16px;
				height: 16px;
			}

			@media (max-width: 900px) {
				.footer-grid {
					grid-template-columns: 1fr 1fr;
					gap: var(--spacing-8);
				}

				.footer-brand {
					grid-column: span 2;
					max-width: none;
				}
			}

			/* Burger breakpoint: the inline menu gives way to the
			   fullscreen mobile menu (Bravada shows the hamburger once
			   the menu no longer fits) */
			@media (max-width: 800px) {
				.nav-right .nav-links {
					display: none;
				}
			}

			@media (max-width: 640px) {
				.site-title {
					font-size: 1.15rem;
				}

				:global(.site-search-input) {
					font-size: var(--font-size-lg) !important;
				}

				.search-cancel {
					right: 1em;
				}

				.nav-admin {
					font-size: var(--font-size-xs);
					white-space: nowrap;
				}

				.footer-grid {
					grid-template-columns: 1fr;
				}

				.footer-brand {
					grid-column: span 1;
				}

				.footer-bottom {
					flex-direction: column;
					gap: var(--spacing-4);
