---
import { getMenu, getSiteSettings } from "emdash";
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import { Font } from "astro:assets";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import { createInSection } from "../utils/nav-section";
import MobileMenu from "./MobileMenu.astro";
import SiteFooter from "./SiteFooter.astro";
import "../styles/tokens.css";
import "../styles/theme.css";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	/** Pass content reference for plugin page contributions on content pages */
	content?: { collection: string; id: string; slug?: string | null };
	/** Bravada over-menu: transparent header floating over a hero */
	overHero?: boolean;
}

const {
	title,
	pageTitle,
	description,
	image,
	canonical,
	robots = "index, follow, max-image-preview:large",
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
	overHero = false,
} = Astro.props;
const { siteTitle, siteLogo } = resolveBlogSiteIdentity(await getSiteSettings());
// Default canonical to the clean current URL (origin + path, no query).
// SSR (output: "server") means Astro.url carries the real request host
// in production, so this resolves correctly once deployed.
const canonicalUrl = canonical ?? `${Astro.url.origin}${Astro.url.pathname}`;
// Open Graph requires absolute image URLs; promote a root-relative path
// to the current origin (SSR carries the real host in production).
const ogImageUrl = image
	? image.startsWith("http")
		? image
		: `${Astro.url.origin}${image}`
	: undefined;
// If title already includes site title (from getSeoMeta), use as-is
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;

// Fetch primary menu defined in seed
const menu = await getMenu("primary");

// Build public page context for plugin contributions
// SEO data is passed here and rendered securely by EmDashHead
const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description,
	canonical: canonicalUrl,
	image: ogImageUrl,
	content,
	seo: { ogImage: ogImageUrl, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

// Section-aware highlighting for the desktop nav: an item is current
// anywhere inside the section its URL owns (the mobile menu does its
// own annotation). Shared logic lives in utils/nav-section.
const inSection = createInSection(Astro.url.pathname);

// Check if user is logged in (for showing admin link)
const isLoggedIn = !!Astro.locals.user;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<Font cssVariable="--font-body" preload />
		<Font cssVariable="--font-display" preload />
		<Font cssVariable="--font-mono" />
		<title>{fullTitle}</title>
		<link
			rel="alternate"
			type="application/rss+xml"
			title={`${siteTitle} » Feed`}
			href="/rss.xml"
		/>
		<EmDashHead page={pageCtx} />
		<script is:inline>
			// Gate the .aos reveal-hiding on JS actually running, so no-JS
			// visitors see all landing-page content.
			document.documentElement.classList.add("js");
		</script>
		<script is:inline>
			// Apply an explicit theme choice immediately to prevent flash.
			// With no cookie, color-scheme: light dark follows the OS.
			(function () {
				var c = document.cookie;
				var i = c.indexOf("theme=");
				var theme = i >= 0 ? c.slice(i + 6).split(";")[0] : null;
				if (theme === "dark" || theme === "light") {
					document.documentElement.classList.add(theme);
				}
			})();
		</script>
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />
		<!-- Bravada preloader: two pulsing dots (gold + teal) on a solid
		     sheet; fades out on window load, CSS animation as a fallback -->
		<div class="cryout-preloader" aria-hidden="true">
			<div class="cryout-preloader-inside">
				<div class="bounce1"></div>
				<div class="bounce2"></div>
			</div>
		</div>
		<header class:list={["site-header", { "over-hero": overHero }]}>
			<nav class="nav">
				<a href="/" class="site-title">
					{siteLogo
						? <img src={siteLogo.url} alt={siteLogo.alt || siteTitle} class="site-logo-img" />
						: siteTitle
					}
				</a>
				<div class="nav-right">
					<ul class="nav-links">
						{
							menu?.items.map((item) => (
								<li
									class:list={[
										"menu-item",
										{
											"has-children": item.children.length > 0,
											current:
												inSection(item.url) ||
												item.children.some((c) => inSection(c.url)),
										},
									]}
								>
									<a href={item.url} target={item.target}>
										<span>{item.label}</span>
									</a>
									{item.children.length > 0 && (
										<ul class="sub-menu">
											{item.children.map((child) => (
												<li
													class:list={[
														{
															"has-children":
																(child.children?.length ?? 0) > 0,
														},
													]}
												>
													<a href={child.url} target={child.target}>
														<span>{child.label}</span>
													</a>
													{(child.children?.length ?? 0) > 0 && (
														<ul class="sub-menu">
															{child.children.map((grand) => (
																<li>
																	<a
																		href={grand.url}
																		target={grand.target}
																	>
																		<span>{grand.label}</span>
																	</a>
																</li>
															))}
														</ul>
													)}
												</li>
											))}
										</ul>
									)}
								</li>
							))
						}
					</ul>
				</div>
				{
					isLoggedIn && (
						<a href="/_emdash/admin" class="nav-admin">
							Admin
						</a>
					)
				}
				<button
					type="button"
					class="hamburger"
					aria-label="Menu"
					aria-expanded="false"
					aria-controls="mobile-menu"
				>
					<span></span>
					<span></span>
					<span></span>
				</button>
			</nav>
		</header>

		<MobileMenu />

		<!-- Bravada menu-search-animated: fullscreen dark layer with a
		     centered pill input that slides up; live results below it -->
		<div
			id="menu-search-overlay"
			class="menu-search-overlay"
			hidden
			role="dialog"
			aria-modal="true"
			aria-label="Search"
		>
			<button type="button" class="search-cancel" aria-label="Close search">
				<svg
					width="28"
					height="28"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					aria-hidden="true"
					><line x1="18" y1="6" x2="6" y2="18"></line><line
						x1="6"
						y1="6"
						x2="18"
						y2="18"></line></svg
				>
			</button>
			<div class="search-shell">
				<LiveSearch
					placeholder="Search…"
					class="site-search"
					inputClass="site-search-input"
					resultsClass="site-search-results"
					resultClass="site-search-result"
					collections={["posts", "pages"]}
				/>
			</div>
		</div>

		<main>
			<slot />
		</main>

		<SiteFooter />

		<style is:global>
			/*
			 * Establish layer order: "base" has lower priority than unlayered
			 * styles, so theme.css overrides always win regardless of source
			 * order in the bundled CSS.
			 */
			@layer base;

			@layer base {
				*:where(:not([class*="emdash"]):not([class*="ec-"])),
				*:where(:not([class*="emdash"]):not([class*="ec-"]))::before,
				*:where(:not([class*="emdash"]):not([class*="ec-"]))::after {
					box-sizing: border-box;
				}

				body,
				h1,
				h2,
				h3,
				h4,
				h5,
				h6,
				p,
				ul,
				ol,
				figure,
				blockquote,
				dl,
				dd {
					margin: 0;
				}

				ul,
				ol {
					padding: 0;
				}

				/*
				 * Design tokens live in src/styles/tokens.css. Colors are
				 * defined with light-dark(); these rules pin the scheme when
				 * the footer switcher sets an explicit choice. With no class,
				 * color-scheme: light dark follows the OS preference. The
				 * @supports guard keeps the toggle from forcing dark UA form
				 * controls on browsers stuck on the plain-light fallback.
				 */
				@supports (color: light-dark(#000, #fff)) {
					:root.light {
						color-scheme: light;
					}

					:root.dark {
						color-scheme: dark;
					}
				}

				html {
					scroll-behavior: smooth;
				}

				body {
					font-family: var(--font-body);
					font-size: var(--font-size-base);
					line-height: var(--leading-relaxed);
					color: var(--color-text);
					background: var(--color-bg);
					-webkit-font-smoothing: antialiased;
					-moz-osx-font-smoothing: grayscale;
					min-height: 100vh;
				}

				a:where(:not([class*="emdash"]):not([class*="ec-"])) {
					color: var(--color-brand);
					text-decoration: none;
					transition: color var(--transition-fast);
				}

				a:where(:not([class*="emdash"]):not([class*="ec-"])):hover {
					color: var(--color-brand-hover);
				}

				img {
					max-width: 100%;
					height: auto;
					display: block;
				}

				h1,
				h2,
				h3,
				h4,
				h5,
				h6 {
					font-family: var(--font-heading);
					line-height: var(--leading-tight);
					font-weight: var(--font-weight-heading);
					letter-spacing: var(--tracking-snug);
				}

				h1 {
					font-weight: var(--font-weight-display);
					letter-spacing: var(--tracking-tight);
				}

				::selection {
					background: var(--color-brand);
					color: var(--color-on-brand);
				}
			}
		</style>

		<style>
			/* Bravada fixed menu: 75px bar pinned to the top. Solid white
			   normally; transparent when floating over a hero until the
			   page scrolls (.header-fixed added by script). */
			.site-header {
				position: sticky;
				top: 0;
				z-index: 100;
				background: var(--color-surface);
				box-shadow: 0 1px 0 var(--color-border-subtle);
				transition:
					background 0.3s ease,
					box-shadow 0.3s ease;
			}

			.site-header.over-hero {
				position: fixed;
				left: 0;
				right: 0;
				box-shadow: none;
			}

			.site-header.over-hero.header-fixed {
				background: var(--color-surface);
				box-shadow: 0 1px 0 var(--color-border-subtle);
			}

			.nav {
				display: flex;
				justify-content: space-between;
				align-items: center;
				max-width: var(--wide-width);
				margin: 0 auto;
				padding: var(--spacing-4) var(--spacing-6);
				height: var(--nav-height);
			}

			.site-title {
				/* Demo #site-title: 1.3em of the 16px root */
				font-size: 1.3rem;
				font-weight: 600;
				color: var(--color-text);
				text-decoration: none;
				letter-spacing: var(--tracking-snug);
			}

			.site-title:hover {
				color: var(--color-brand);
			}

			.site-logo-img {
				height: 48px;
				width: auto;
				display: block;
				margin: -8px 0;
			}

			.nav-right {
				display: flex;
				align-items: center;
				gap: var(--spacing-6);
				margin-inline-start: auto;
			}

			/* Demo #access: no gap between items — each link carries
			   0 2em padding (1.4em under 1200px), so the hover wash pill
			   hugs the label like the original */
			.nav-links {
				display: flex;
				margin: 0;
				padding: 0;
				list-style: none;
				font-size: var(--font-size-base);
			}

			.nav-links .menu-item {
				position: relative;
			}

			/* Demo top-level hover is the wash pill only — no color change */
			.nav-links a {
				text-decoration: none;
				color: var(--color-text);
				transition: color var(--transition-fast);
			}

			/* Current section: gold like the demo's current-menu-item */
			.nav-links .menu-item.current > a {
				color: var(--color-gold);
			}

			.nav-links .menu-item > a {
				display: block;
				padding: 0 2em;
				line-height: var(--nav-height);
			}

			@media (max-width: 1200px) {
				.nav-links .menu-item > a {
					padding: 0 1.4em;
				}
			}

			/* Dropdowns: Bravada's dark teal submenu panel. It slides DOWN
			   into place from -25px (demo: #access ul ul) with a soft
			   drop shadow; item labels get a translucent white wash on
			   hover (.sub-menu li a:hover span). */
			/* Demo #access ul ul: transparent panel aligned to the item's
			   left edge, min-width 125%, sliding down from -25px over
			   .2s ease-in. Each LINK carries the dark teal background. */
			.nav-links .sub-menu {
				position: absolute;
				top: 100%;
				left: 0;
				z-index: 1000;
				min-width: 125%;
				margin: 0;
				padding: 0;
				list-style: none;
				box-shadow: 10px 10px 20px rgba(0, 0, 0, 0.05);
				opacity: 0;
				visibility: hidden;
				transform: translateY(-25px);
				transition: 0.2s all ease-in;
			}

			/* Caret pointing up at the parent item (demo
			   #access > div > ul > li > ul::before, border-bottom teal) —
			   first level only; flyouts have no caret */
			.nav-links > .menu-item > .sub-menu::before {
				content: "";
				position: absolute;
				bottom: 100%;
				left: 2em;
				border: 6px solid transparent;
				border-bottom-color: var(--color-submenu-bg);
			}

			/* Third level flyout (demo #access ul ul ul): opens beside its
			   parent row, 10px out, no vertical slide */
			.nav-links .sub-menu .sub-menu {
				top: 0;
				left: calc(100% + 10px);
				transform: none;
			}

			.nav-links .sub-menu li {
				position: relative;
			}

			.nav-links .sub-menu li.has-children:hover > .sub-menu,
			.nav-links .sub-menu li.has-children:focus-within > .sub-menu {
				opacity: 1;
				visibility: visible;
			}

			/* Flyout-parent arrow (demo: a 6px teal triangle at the row's
			   right edge that nudges outward on hover) */
			.nav-links .sub-menu li.has-children > a::after {
				content: "";
				position: absolute;
				top: 0;
				bottom: 0;
				left: calc(100% - 6px);
				width: 6px;
				height: 6px;
				margin: auto;
				border: 6px solid transparent;
				border-left-color: var(--color-submenu-bg);
				transition: all 0.3s ease-out;
			}

			.nav-links .sub-menu li.has-children:hover > a::after {
				left: 100%;
			}

			.nav-links .sub-menu li.has-children > a {
				position: relative;
			}

			/* Right-pointing chevron on flyout parents, anchored to the
			   row's right edge like the demo (span::after, absolute,
			   right .25em); fades out as the arrow nudges on hover. The
			   label reserves room for it. */
			.nav-links .sub-menu li.has-children > a > span {
				padding-right: 2em;
			}

			.nav-links .sub-menu li.has-children > a > span::after {
				content: "";
				position: absolute;
				top: 0;
				bottom: 0;
				right: 0.9em;
				width: 0.45em;
				height: 0.45em;
				margin: auto;
				border-right: 1.5px solid currentColor;
				border-bottom: 1.5px solid currentColor;
				transform: rotate(-45deg);
				opacity: 0.5;
				transition: 0.3s ease-out all;
			}

			.nav-links .sub-menu li.has-children:hover > a > span::after {
				opacity: 0;
			}

			.nav-links .menu-item:hover > .sub-menu,
			.nav-links .menu-item:focus-within > .sub-menu {
				opacity: 1;
				visibility: visible;
				transform: translateY(0);
			}

			/* Demo #access ul li: items never wrap — panels grow instead */
			.nav-links .menu-item,
			.nav-links .sub-menu li {
				white-space: nowrap;
			}

			.nav-links .sub-menu li {
				min-width: 150px;
			}

			/* Demo: #access ul li a { font-size: 1em } with line-height 3;
			   white on #066664, gold on hover */
			.nav-links .sub-menu a {
				display: block;
				padding: 0;
				font-size: 1em;
				line-height: 3;
				background: var(--color-submenu-bg);
				color: #ffffff !important;
				transition: 0.3s color ease-out;
			}

			.nav-links .sub-menu a:hover,
			.nav-links .sub-menu a:focus-visible {
				color: var(--color-gold) !important;
			}

			.nav-links .sub-menu a span {
				display: block;
				padding: 0.3em 1.5em;
				transition: 0.2s ease-out all;
			}

			.nav-links .sub-menu a:hover span,
			.nav-links .sub-menu a:focus-visible span {
				background: rgba(255, 255, 255, 0.1);
			}

			/* Bravada preloader (demo .cryout-preloader): fixed sheet with
			   two dots pulsing via preloader-spin 1.4s (second dot offset
			   -.7s); the 6s CSS animation hides it even if JS never runs */
			.cryout-preloader {
				position: fixed;
				inset: 0;
				z-index: 99999;
				display: flex;
				align-items: center;
				justify-content: center;
				background: var(--color-bg);
				/* Invisible for the first 150ms so fast loads never flash
				   it; only slow loads ever see the sheet appear */
				opacity: 0;
				animation:
					preloader-appear 0s linear 0.15s forwards,
					preloader-hide 6s 1s ease-out forwards;
				transition: opacity 0.7s ease-out;
			}

			@keyframes preloader-appear {
				to {
					opacity: 1;
				}
			}

			.cryout-preloader-inside {
				position: relative;
				width: 50px;
				height: 50px;
			}

			.cryout-preloader-inside .bounce1,
			.cryout-preloader-inside .bounce2 {
				position: absolute;
				inset: 0;
				border-radius: 50%;
				animation: preloader-spin 1.4s ease-in-out infinite;
			}

			.cryout-preloader-inside .bounce1 {
				background: var(--color-gold);
			}

			.cryout-preloader-inside .bounce2 {
				background: var(--color-teal-solid);
				animation-delay: -0.7s;
			}

			@keyframes preloader-spin {
				0% {
					transform: scale(0);
				}
				100% {
					transform: scale(1);
					opacity: 0;
				}
			}

			@keyframes preloader-hide {
				100% {
					visibility: hidden;
					opacity: 0;
					z-index: -1;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.cryout-preloader {
					display: none;
				}
			}

			.search-cancel:focus-visible {
				outline: 2px solid var(--color-teal);
				outline-offset: 2px;
			}

			.nav-admin {
				font-size: var(--font-size-sm);
				color: var(--color-text-secondary);
				text-decoration: none;
				transition: color var(--transition-fast);
			}

			.nav-admin:hover {
				color: var(--color-text);
			}

			/* Fullscreen menu search (Bravada #access .menu-search-animated):
			   dark layer, white pill input sliding up from +150px */
			.menu-search-overlay {
				position: fixed;
				inset: 0;
				z-index: 1000;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				padding: 1em;
				background: rgba(0, 0, 0, 0.8);
			}

			.menu-search-overlay[hidden] {
				display: none;
			}

			.search-cancel {
				position: absolute;
				top: 1em;
				right: 3em;
				display: flex;
				align-items: center;
				justify-content: center;
				width: 44px;
				height: 44px;
				border: none;
				background: none;
				color: rgba(255, 255, 255, 0.75);
				cursor: pointer;
				transition: color 0.2s ease-out;
			}

			.search-cancel:hover {
				color: #ffffff;
			}

			.search-shell {
				width: min(860px, 92vw);
			}

			.search-shell :global(.site-search) {
				position: relative;
				display: block;
				width: 100%;
				--emdash-search-border-focus: transparent;
			}

			:global(.site-search-input) {
				width: 100% !important;
				height: 3.5em !important;
				padding: 0 1.5em !important;
				border: 0 !important;
				border-radius: 100px !important;
				font-family: var(--font-body) !important;
				font-size: 1.5em !important;
				line-height: 2 !important;
				font-weight: 400;
				text-align: center;
				background: #ffffff !important;
				color: #555555 !important;
				box-shadow: 0 0 15px 15px rgba(0, 0, 0, 0.25);
				opacity: 0;
				transform: translateY(150px);
				transition: 0.25s ease-in-out all;
			}

			.menu-search-overlay.is-active :global(.site-search-input) {
				opacity: 1;
				transform: translateY(0);
			}

			:global(.site-search-input)::-webkit-search-cancel-button {
				-webkit-appearance: none;
				appearance: none;
			}

			:global(.site-search-input)::placeholder {
				color: #a7a7a7;
			}

			:global(.site-search-input):focus,
			:global(.site-search-input):focus-visible {
				outline: none;
				border: 0 !important;
			}

			:global(.site-search-results) {
				position: absolute;
				top: 100%;
				left: 0;
				right: 0;
				margin-top: var(--spacing-3);
				background: var(--color-surface);
				border: 1px solid var(--color-border);
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-lg);
				max-height: min(50vh, 400px);
				overflow-y: auto;
				z-index: 1000;
			}

			:global(.site-search-results .emdash-live-search-loading),
			:global(.site-search-results .emdash-live-search-no-results) {
				padding: var(--spacing-4);
				text-align: center;
				color: var(--color-muted);
				font-size: var(--font-size-sm);
			}

			:global(.site-search-result) {
				display: block;
				padding: var(--spacing-3) var(--spacing-4);
				text-decoration: none;
				color: var(--color-text);
				border-bottom: 1px solid var(--color-border-subtle);
				transition: background var(--transition-fast);
			}

			:global(.site-search-result):last-child {
				border-bottom: none;
			}

			:global(.site-search-result):hover,
			:global(.site-search-result):focus,
			:global(.site-search-result.focused) {
				background: var(--color-surface);
				outline: none;
			}

			:global(.site-search-result .emdash-live-search-result-title) {
				display: block;
				font-weight: 500;
				font-size: var(--font-size-sm);
			}

			:global(.site-search-result .emdash-live-search-result-collection) {
				display: block;
				font-size: var(--font-size-xs);
				color: var(--color-muted);
				text-transform: uppercase;
				letter-spacing: var(--tracking-wide);
				margin-top: 2px;
			}

			:global(.site-search-result .emdash-live-search-result-snippet) {
				display: block;
				font-size: var(--font-size-sm);
				color: var(--color-muted);
				margin-top: var(--spacing-1);
				line-height: var(--leading-snug);
			}

			:global(.site-search-result .emdash-live-search-result-snippet mark) {
				font-weight: 600;
				color: var(--color-text);
			}

			main {
				min-height: calc(100vh - var(--nav-height) - 300px);
			}

			.sr-only {
				position: absolute;
				width: 1px;
				height: 1px;
				padding: 0;
				margin: -1px;
				overflow: hidden;
				clip: rect(0, 0, 0, 0);
				white-space: nowrap;
				border: 0;
			}

			/* Hamburger (Bravada .hamburger): three right-aligned bars
			   (100/75/45%) that fill on hover and morph into an X. Shown at
			   all widths like the demo — it opens the fullscreen side menu */
			.hamburger {
				display: inline-block;
				position: relative;
				align-self: center;
				width: 36px;
				height: 20px;
				margin-left: 1em;
				border: 0;
				padding: 0;
				background: transparent;
				cursor: pointer;
				transition: 0.5s ease-in-out;
			}

			.hamburger span {
				display: block;
				position: absolute;
				right: 0;
				height: 2px;
				width: 100%;
				border-radius: 3px;
				background: var(--color-menu-link);
				transition: 0.25s ease-in-out;
			}

			.site-header.over-hero:not(.header-fixed) .hamburger span {
				background: #ffffff;
			}

			.hamburger span:nth-child(1) {
				top: 0;
				transform-origin: left top;
			}

			.hamburger span:nth-child(2) {
				top: 9px;
				width: 75%;
				transform-origin: left center;
			}

			.hamburger span:nth-child(3) {
				top: 18px;
				width: 45%;
				transform-origin: left bottom;
			}

			.hamburger:hover span {
				width: 100%;
			}

			:global(body.burgermenu-active) .hamburger span {
				width: 100%;
				background: #ffffff;
			}

			:global(body.burgermenu-active) .hamburger span:nth-child(1) {
				top: -3px;
				transform: rotate(45deg);
			}

			:global(body.burgermenu-active) .hamburger span:nth-child(2) {
				width: 0;
				opacity: 0;
				transform: translateX(-50%);
			}

			:global(body.burgermenu-active) .hamburger span:nth-child(3) {
				top: 22px;
				transform: rotate(-45deg);
			}

			/* While the burger menu is open the header floats above the teal
			   layer: the menu links slide away (demo .burgermenu-active
			   #access) and the hamburger — morphed into an X — stays exactly
			   where it was clicked, acting as the close button. */
			:global(body.burgermenu-active) .site-header,
			:global(body.burgermenu-active) .site-header.over-hero.header-fixed {
				z-index: 1001;
				background: transparent;
				box-shadow: none;
			}

			:global(body.burgermenu-active) .nav-right .nav-links,
			:global(body.burgermenu-active) .nav-admin {
				opacity: 0;
				transform: translateX(50px);
				pointer-events: none;
			}

			.nav-right .nav-links,
			.nav-admin {
				transition: 0.3s ease-out all;
			}

			:global(body.burgermenu-active) .site-title {
				color: #ffffff !important;
			}

			:global(body.burgermenu-active) .site-title::before {
				background: var(--color-gold);
			}

			:global(body.noscroll) {
				overflow: hidden;
			}


			/* Burger breakpoint: the inline menu gives way to the
			   fullscreen mobile menu (Bravada shows the hamburger once
			   the menu no longer fits) */
			@media (max-width: 800px) {
				.nav-right .nav-links {
					display: none;
				}
			}

			@media (max-width: 640px) {
				.site-title {
					font-size: 1.15rem;
				}

				:global(.site-search-input) {
					font-size: var(--font-size-lg) !important;
				}

				.search-cancel {
					right: 1em;
				}

				.nav-admin {
					font-size: var(--font-size-xs);
					white-space: nowrap;
				}
			}
		</style>

		<button id="toTop" aria-label="Back to top">
			<svg
				width="20"
				height="20"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"><polyline points="18 15 12 9 6 15"></polyline></svg
			>
			<svg
				width="20"
				height="20"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"><polyline points="18 15 12 9 6 15"></polyline></svg
			>
		</button>

		<script>
			// Bravada fixed-menu scroll state: the over-hero header turns
			// solid once the page scrolls past the top; the back-to-top
			// button fades in after a screenful.
			const header = document.querySelector(".site-header");
			const toTop = document.getElementById("toTop");

			function onScroll() {
				const y = window.scrollY;
				header?.classList.toggle("header-fixed", y > 30);
				toTop?.classList.toggle("visible", y > window.innerHeight);
			}

			onScroll();
			window.addEventListener("scroll", onScroll, { passive: true });

			toTop?.addEventListener("click", () => {
				window.scrollTo({ top: 0, behavior: "smooth" });
			});
		</script>

		<script>
			// Preloader dismissal (demo cryoutPreloader): fade on window
			// load, then remove; the CSS animation is the no-JS fallback.
			const pre = document.querySelector<HTMLElement>(".cryout-preloader");
			if (pre) {
				const done = () => {
					// Pin the animation-driven opacity before removing the
					// animation so the .7s fade-out starts from it (fast
					// loads are still at 0 and never appear at all)
					pre.style.opacity = getComputedStyle(pre).opacity;
					pre.style.animation = "none";
					void pre.offsetWidth;
					pre.style.opacity = "0";
					pre.style.pointerEvents = "none";
					setTimeout(() => pre.remove(), 750);
				};
				// Dismiss at max(document parsed, hero image decoded),
				// capped at 2.5s — the hero is the one above-the-fold
				// visual worth holding for; waiting for window load would
				// hold the sheet for every hotlinked image while content
				// sits painted beneath it. Cache-hit loads clear both
				// gates inside the 150ms invisibility window.
				const heroReady = () =>
					new Promise<void>((resolve) => {
						const hero = document.querySelector<HTMLImageElement>(
							".lp-staticslider-image, .page-hero-image"
						);
						if (!hero || hero.complete) return resolve();
						hero.addEventListener("load", () => resolve(), { once: true });
						hero.addEventListener("error", () => resolve(), { once: true });
					});
				const domReady = () =>
					new Promise<void>((resolve) => {
						if (document.readyState !== "loading") return resolve();
						document.addEventListener("DOMContentLoaded", () => resolve(), {
							once: true,
						});
					});
				const cap = new Promise<void>((resolve) => setTimeout(resolve, 2500));
				Promise.race([Promise.all([domReady(), heroReady()]), cap]).then(done);
			}

			// Lazy-image fade-in (demo cryoutAnimateLazyImages): content
			// images marked lazy get .animate-lazy once loaded.
			for (const img of document.querySelectorAll<HTMLImageElement>(
				'img[loading="lazy"]'
			)) {
				if (img.complete) img.classList.add("animate-lazy");
				else
					img.addEventListener(
						"load",
						() => img.classList.add("animate-lazy"),
						{ once: true }
					);
			}
		</script>

		<script>
			// Bravada on-scroll reveals: elements start with .aos + a
			// direction class (see theme.css); remove .aos when they enter
			// the viewport so the transition plays.
			const aosEls = document.querySelectorAll(".aos");
			if (aosEls.length > 0 && "IntersectionObserver" in window) {
				const io = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.remove("aos");
								io.unobserve(entry.target);
							}
						}
					},
					{ rootMargin: "0px 0px -10% 0px" }
				);
				aosEls.forEach((el) => io.observe(el));
			} else {
				aosEls.forEach((el) => el.classList.remove("aos"));
			}
		</script>

		<script>
			// Inert "#" dropdown parents in the top menu (demo behavior:
			// they don't navigate; the dropdown opens on hover/focus)
			document
				.querySelectorAll<HTMLAnchorElement>('.nav-links a[href="#"]')
				.forEach((a) => {
					a.addEventListener("click", (e) => e.preventDefault());
				});
		</script>

		<script>
			// Bravada animated menu search: the nav icon opens a fullscreen
			// dark layer; the pill input slides up once it's visible.
			// Esc, ✕, or a click on the backdrop closes it. ⌘K/Ctrl+K opens
			// it too.
			const overlay = document.getElementById("menu-search-overlay");
			const toggle = document.querySelector<HTMLButtonElement>(".search-toggle");
			const cancel = overlay?.querySelector<HTMLButtonElement>(".search-cancel");
			const input = overlay?.querySelector<HTMLInputElement>(".site-search-input");

			function openSearch() {
				if (!overlay) return;
				overlay.hidden = false;
				toggle?.setAttribute("aria-expanded", "true");
				// Two frames so the unhide commits before the slide-up plays
				requestAnimationFrame(() =>
					requestAnimationFrame(() => {
						overlay.classList.add("is-active");
						input?.focus();
					})
				);
			}

			function closeSearch() {
				if (!overlay || overlay.hidden) return;
				overlay.classList.remove("is-active");
				toggle?.setAttribute("aria-expanded", "false");
				setTimeout(() => {
					overlay.hidden = true;
				}, 250);
				toggle?.focus();
			}

			toggle?.addEventListener("click", openSearch);
			cancel?.addEventListener("click", closeSearch);
			overlay?.addEventListener("click", (e) => {
				if (e.target === overlay) closeSearch();
			});
			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape") closeSearch();
				if ((e.metaKey || e.ctrlKey) && e.key === "k") {
					e.preventDefault();
					overlay?.hidden ? openSearch() : input?.focus();
				}
			});
		</script>
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
