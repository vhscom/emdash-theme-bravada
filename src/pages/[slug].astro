---
import { getEmDashEntry, decodeSlug } from "emdash";
import RichText from "../components/RichText.astro";
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
import PageLayout from "../layouts/PageLayout.astro";
import { metaDescription } from "../utils/reading-time";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: page, cacheHint } = await getEmDashEntry("pages", slug);

if (!page) {
	return Astro.redirect("/404");
}

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

// Pages that open with their own Bravada slider (e.g. a landing page)
// skip the standard fullscreen page header.
const firstBlock = page.data.content?.[0];
const hasOwnHero = firstBlock?._type === "bravada.hero";

// Social preview image: the page's leading hero slide, if it has one.
const ogImage =
	hasOwnHero && typeof firstBlock.image === "string" ? firstBlock.image : undefined;

// Bravada per-page layout (the demo's Layouts pages): a select field
// on the pages collection — none | left | right | two-left |
// two-right | sided. The column arrangement lives in <PageLayout>.
const layout = (page.data.layout as string) || "none";

// Per-page header image (the demo gives each template page its own
// photo); falls back to PageHeader's site-wide default when unset.
const headerImage = page.data.header_image as { src?: string; alt?: string } | undefined;
---

<Base
	title={page.data.title}
	description={metaDescription(page.data.content) ?? page.data.title}
	image={ogImage}
	content={{ collection: "pages", id: page.data.id, slug }}
	overHero
>
	{
		!hasOwnHero && (
			<PageHeader
				title={page.data.title}
				image={headerImage?.src}
				imageAlt={headerImage?.alt ?? ""}
				crumbs={[{ label: page.data.title }]}
				titleAttrs={page.edit.title}
			/>
		)
	}
	<PageLayout layout={layout} sidebar={page.data.sidebar as string | null}>
		<RichText value={page.data.content} />
	</PageLayout>
</Base>
