---
import {
	getTerm,
	getEmDashCollection,
	getTermsForEntries,
	decodeSlug,
} from "emdash";
import Base from "../../layouts/Base.astro";
import PageHeader from "../../components/PageHeader.astro";
import ArchiveLayout from "../../layouts/ArchiveLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";

const slug = decodeSlug(Astro.params.slug);
const term = slug ? await getTerm("category", slug) : null;

if (!term) {
	return Astro.rewrite("/404");
}

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	where: { category: term.slug },
	orderBy: { published_at: "desc" },
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

// Single batched query for tags on every post in this category, rather
// than calling getEntryTerms() per post.
const tagsByEntry = await getTermsForEntries(
	"posts",
	posts.map((p) => p.data.id),
	"tag",
);
const cards = posts.map((post) => ({
	post,
	tags: (tagsByEntry.get(post.data.id) ?? []).map((t) => ({
		slug: t.slug,
		label: t.label,
	})),
	bylines: post.data.bylines ?? [],
}));
---

<Base
	title={`${term.label} posts`}
	description={`All posts in ${term.label}`}
	overHero
>
	<PageHeader
		title={term.label}
		excerpt={term.description}
		subtitle={`Category · ${posts.length} ${posts.length === 1 ? "post" : "posts"}`}
		crumbs={[{ label: "Blog", href: "/posts" }, { label: term.label }]}
	/>

	<ArchiveLayout>
		{
			cards.length === 0 ? (
				<p class="empty">No posts in this category yet.</p>
			) : (
				<div class="archive-grid">
					{cards.map(({ post, tags, bylines }) => (
						<PostCard
							title={post.data.title}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={`/posts/${post.id}`}
							date={post.data.publishedAt ?? undefined}
							readingTime={getReadingTime(post.data.content)}
							tags={tags}
							bylines={bylines}
						/>
					))}
				</div>
			)
		}
	</ArchiveLayout>
</Base>

<style>
	.archive-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2em;
		align-items: start;
	}

	.empty {
		color: var(--color-muted);
	}

	@media (max-width: 640px) {
		.archive-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
