---
import { getEmDashEntry, decodeSlug } from "emdash";
import RichText from "../../components/RichText.astro";
import Base from "../../layouts/Base.astro";
import PageHeader from "../../components/PageHeader.astro";
import SidebarWidgets from "../../components/SidebarWidgets.astro";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: page, cacheHint } = await getEmDashEntry("pages", slug);

if (!page) {
	return Astro.redirect("/404");
}

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

// Pages that open with their own Bravada slider (e.g. a landing page)
// skip the standard fullscreen page header.
const hasOwnHero = page.data.content?.[0]?._type === "bravada.hero";

// Bravada per-page layout (the demo's Layouts pages): a select field
// on the pages collection — none | left | right | two-left |
// two-right | sided. Sidebars are the admin-editable "sidebar" and
// "sidebar-b" widget areas.
const layout = (page.data.layout as string) || "none";
const hasPrimary = layout !== "none";
const hasSecondary = ["two-left", "two-right", "sided"].includes(layout);
---

<Base
	title={page.data.title}
	content={{ collection: "pages", id: page.data.id, slug }}
	overHero
>
	{
		!hasOwnHero && (
			<PageHeader
				title={page.data.title}
				crumbs={[{ label: page.data.title }]}
				titleAttrs={page.edit.title}
			/>
		)
	}
	<div class:list={["page-shell", `layout-${layout}`]}>
		{hasPrimary && <SidebarWidgets name="page-sidebar" />}
		<article class="page-article">
			<div class="page-content">
				<RichText value={page.data.content} />
			</div>
		</article>
		{hasSecondary && <SidebarWidgets name="sidebar-b" />}
	</div>
</Base>

<style>
	/* Demo static page: content on a white card inside the shell.
	   The shell arranges the card and up to two 320px sidebars per the
	   page's Layout field (demo one/two/three-column options). */
	/* Demo #container: one white sheet holding content + sidebars */
	.page-shell {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 3em;
		max-width: calc(var(--wide-width) - 4em);
		margin: 4em auto;
		padding: 3.5em clamp(1.5em, 4vw, 3.5em);
		background: var(--color-surface);
	}

	.page-shell.layout-left {
		grid-template-columns: 320px minmax(0, 1fr);
	}

	.page-shell.layout-right {
		grid-template-columns: minmax(0, 1fr) 320px;
	}

	.page-shell.layout-right > .page-article {
		order: -1;
	}

	.page-shell.layout-two-left {
		grid-template-columns: 320px 320px minmax(0, 1fr);
	}

	.page-shell.layout-two-left > .page-article {
		order: 2;
	}

	.page-shell.layout-two-right {
		grid-template-columns: minmax(0, 1fr) 320px 320px;
	}

	.page-shell.layout-two-right > .page-article {
		order: -1;
	}

	.page-shell.layout-sided {
		grid-template-columns: 320px minmax(0, 1fr) 320px;
	}

	.page-article {
		min-width: 0;
	}

	@media (max-width: 1100px) {
		.page-shell,
		.page-shell.layout-left,
		.page-shell.layout-right,
		.page-shell.layout-two-left,
		.page-shell.layout-two-right,
		.page-shell.layout-sided {
			grid-template-columns: 1fr;
		}

		.page-shell > .page-article {
			order: -1;
		}

		.page-shell {
			margin: 2em auto;
		}
	}

	.page-content :global(p) {
		margin-bottom: 1.5em;
	}

	.page-content :global(h2) {
		font-size: var(--font-size-2xl);
		margin-top: 2em;
		margin-bottom: 0.75em;
	}

	.page-content :global(h3) {
		font-size: var(--font-size-xl);
		margin-top: 1.75em;
		margin-bottom: 0.5em;
	}

	.page-content :global(blockquote) {
		margin: 1.5em 0;
		padding-left: var(--spacing-6);
		border-left: 3px solid var(--color-border);
		color: var(--color-muted);
	}

	.page-content :global(pre) {
		margin: 1.5em 0;
		padding: var(--spacing-4);
		background: var(--color-surface);
		border-radius: var(--radius);
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
	}

	.page-content :global(code) {
		font-family: var(--font-mono);
		font-size: 0.9em;
		background: var(--color-surface);
		padding: 0.15em 0.3em;
		border-radius: var(--radius);
	}

	.page-content :global(pre code) {
		background: none;
		padding: 0;
	}

	.page-content :global(ul),
	.page-content :global(ol) {
		margin-bottom: 1.5em;
		padding-left: var(--spacing-5);
	}

	.page-content :global(li) {
		margin-bottom: 0.5em;
	}
</style>
