---
import { getEmDashEntry, getEntryTerms, decodeSlug, getSiteSettings } from "emdash";
import Base from "../../layouts/Base.astro";
import PageHeader from "../../components/PageHeader.astro";
import ProjectShell from "../../layouts/ProjectShell.astro";
import ProjectFeatured from "../../components/blocks/ProjectFeatured.astro";
import RichText from "../../components/RichText.astro";
import { getMediaUrl } from "../../utils/media-url";
import { metaDescription } from "../../utils/reading-time";
import { resolveSiteOrigin } from "../../utils/site-identity";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.rewrite("/404");
}

const { entry: project, cacheHint } = await getEmDashEntry("portfolio", slug);

if (!project) {
	return Astro.rewrite("/404");
}

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const [types, tags] = await Promise.all([
	getEntryTerms("portfolio", project.data.id, "project-type"),
	getEntryTerms("portfolio", project.data.id, "project-tag"),
]);

// schema.org/CreativeWork JSON-LD for the project.
const siteOrigin = resolveSiteOrigin(await getSiteSettings(), Astro.url.origin);
const featuredImagePath = getMediaUrl(project.data.featured_image);
const description = metaDescription(project.data.content);
const workLd = {
	"@context": "https://schema.org",
	"@type": "CreativeWork",
	name: project.data.title,
	url: `${siteOrigin}/portfolio/${slug}`,
	...(featuredImagePath && {
		image: featuredImagePath.startsWith("http")
			? featuredImagePath
			: `${siteOrigin}${featuredImagePath}`,
	}),
	...(description && { description }),
	...(project.data.date && { dateCreated: project.data.date }),
	...(types.length > 0 && { genre: types.map((t) => t.label) }),
	...(tags.length > 0 && { keywords: tags.map((t) => t.label).join(", ") }),
};
---

<Base
	title={project.data.title}
	description={description}
	image={featuredImagePath}
	content={{ collection: "portfolio", id: project.data.id, slug }}
	overHero
>
	<PageHeader
		title={project.data.title}
		crumbs={[
			{ label: "Project", href: "/portfolio" },
			{ label: project.data.title },
		]}
		titleAttrs={project.edit.title}
	/>
	<ProjectShell>
		<ProjectFeatured
			node={{
				image: getMediaUrl(project.data.featured_image),
				alt: project.data.title,
				date: project.data.date,
				types: types.map((t) => ({ label: t.label, slug: t.slug })),
				tags: tags.map((t) => ({ label: t.label, slug: t.slug })),
			}}
		/>
		<RichText value={project.data.content} />
	</ProjectShell>
	<script type="application/ld+json" is:inline set:html={JSON.stringify(workLd)} />
</Base>
