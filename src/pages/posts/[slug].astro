---
import {
	getEmDashEntry,
	getEmDashCollection,
	getSeoMeta,
	decodeSlug,
	getSiteSettings,
	getCommentCount,
	getCollectionInfo,
} from "emdash";
import { Comments, CommentForm } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import PageHeader from "../../components/PageHeader.astro";
import RichText from "../../components/RichText.astro";
import SidebarWidgets from "../../components/SidebarWidgets.astro";
import { getReadingTime } from "../../utils/reading-time";
import { resolveBlogSiteIdentity } from "../../utils/site-identity";
import { getMediaUrl } from "../../utils/media-url";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

// Get featured image URL for OG fallback
// The image may have src (external) or meta.storageKey (local)
function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	// Check for direct src
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	// Build from storageKey for local images
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);
const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());

// Generate SEO meta from content
const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
	defaultOgImage: featuredImageUrl,
});

// Bylines are already hydrated by getEmDashEntry
const bylines = post.data.bylines ?? [];

// Get reading time
const readingTime = getReadingTime(post.data.content);

// This post's tags are already hydrated onto the entry by getEmDashEntry —
// no extra query needed.
const tags = post.data.terms?.tag ?? [];

// Fetch a few extra recent posts in case the current post is among them.
const { entries: recentPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 4,
});
const otherPosts = recentPosts.filter((p) => p.id !== post.id).slice(0, 3);

// Adjacent posts for the floating prev/next navigation (demo #nav-fixed).
// Newest-first list: the newer neighbour sits before this post, the
// older one after. "Previous" is older (left), "Next" is newer (right),
// matching the demo's WordPress convention.
const { entries: allPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 200,
});
const postIndex = allPosts.findIndex((p) => p.id === post.id);
const newerPost = postIndex > 0 ? allPosts[postIndex - 1] : null;
const olderPost =
	postIndex >= 0 && postIndex < allPosts.length - 1 ? allPosts[postIndex + 1] : null;
const olderImg = getMediaUrl(olderPost?.data.featured_image);
const newerImg = getMediaUrl(newerPost?.data.featured_image);

// Where a neighbour is missing (first/last post) the demo fills that
// panel with the site's hero image — the same one on the home page —
// as a static, non-clickable placeholder. Only worth fetching when a
// side is actually missing.
let heroImg: string | undefined;
if (!olderPost || !newerPost) {
	const home = await getEmDashEntry("pages", "home");
	const heroBlock = home?.entry?.data.content?.[0];
	heroImg =
		heroBlock?._type === "bravada.hero" && typeof heroBlock.image === "string"
			? heroBlock.image
			: undefined;
}

// Comments are enabled per-collection; the demo only shows the comment
// count badge on related cards when they are on (the default).
const collectionInfo = await getCollectionInfo("posts");
const commentsEnabled = collectionInfo?.commentsEnabled ?? true;
const postCommentCount = commentsEnabled
	? await getCommentCount("posts", post.data.id)
	: 0;

// Related cards (demo .related-item): thumbnail + comment-count badge +
// title + date. Counts only queried when comments are enabled.
const shortDate = (d?: Date | null) =>
	d?.toLocaleDateString("en-US", { month: "long", day: "numeric" }) ?? null;
const relatedPosts = await Promise.all(
	otherPosts.map(async (p) => ({
		id: p.id,
		title: p.data.title,
		img: getMediaUrl(p.data.featured_image),
		date: shortDate(p.data.publishedAt),
		commentCount: commentsEnabled ? await getCommentCount("posts", p.data.id) : 0,
	})),
);

const headerMeta = [
	...(post.data.bylines ?? []).slice(0, 2).map((c) => c.byline.displayName),
]
	.filter(Boolean)
	.join(", ");

const publishDate =
	post.data.publishedAt?.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}) ?? null;
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
	overHero
>
	<PageHeader
		title={post.data.title}
		subtitle={[headerMeta, publishDate, `${readingTime} min read`]
			.filter(Boolean)
			.join("  ·  ")}
		image={featuredImageUrl}
		imageAlt={post.data.title}
		crumbs={[{ label: "Blog", href: "/posts" }, { label: post.data.title }]}
		titleAttrs={post.edit.title}
	/>
	<div class="post-grid">
		{/* One white card holds the article, related posts and comments;
		    the sidebar sits alongside (demo: constrained inside .main). */}
		<div class="post-main">
			<article>
				<header class="article-header">
					<div class="article-meta">
						{
							bylines.length > 0 && (
								<>
									<span class="article-meta-byline">
										{bylines.map((credit, i) => (
											<>
												{i > 0 && ", "}
												{credit.byline.displayName}
											</>
										))}
									</span>
									<span class="meta-dot" />
								</>
							)
						}
						{
							publishDate && (
								<>
									<time>{publishDate}</time>
									<span class="meta-dot" />
								</>
							)
						}
						<span>{readingTime} min read</span>
					</div>
					{
						post.data.excerpt && (
							<p class="article-excerpt" {...post.edit.excerpt}>{post.data.excerpt}</p>
						)
					}
				</header>

				<div class="article-content">
					<RichText value={post.data.content} />
				</div>

				{
					tags.length > 0 && (
						<footer class="article-tags">
							<span class="article-tags-label">Tags:</span>
							{tags.map((t) => (
								<a href={`/tag/${t.slug}`} class="article-tag">
									{t.label}
								</a>
							))}
						</footer>
					)
				}
			</article>

			{
				relatedPosts.length > 0 && (
					<section class="related-posts">
						<h2 class="section-title"><span>Related Posts</span></h2>
						<ul class="related-grid">
							{relatedPosts.map((p) => (
								<li class="related-item">
									<div class="related-thumb">
										<a href={`/posts/${p.id}`} class="related-thumb-frame" tabindex="-1">
											{p.img && <img src={p.img} alt="" loading="lazy" />}
										</a>
										{commentsEnabled && (
											<a href={`/posts/${p.id}#comments`} class="related-comments" aria-label={`${p.commentCount} comments`}>
												<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 2H4a2 2 0 0 0-2 2v18l4-4h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z" /></svg>
												{p.commentCount}
											</a>
										)}
									</div>
									<a href={`/posts/${p.id}`} class="related-name">{p.title}</a>
									{p.date && <p class="related-date">{p.date}</p>}
								</li>
							))}
						</ul>
					</section>
				)
			}

			<section class="post-comments">
				{postCommentCount > 0 && (
					<h2 class="section-title comments-count-title">
						<span>{postCommentCount} {postCommentCount === 1 ? "Comment" : "Comments"}</span>
					</h2>
				)}
				<Comments collection="posts" contentId={post.data.id} threaded />
				<h2 class="section-title reply-title"><span>Leave a Reply</span></h2>
				<CommentForm collection="posts" contentId={post.data.id} />
			</section>
		</div>

		<SidebarWidgets name="sidebar-b" />
	</div>

	{
		(olderPost || newerPost) && (
			<nav id="nav-below" aria-label="Previous and next post">
				{olderPost ? (
					<a class="nav-below-prev" href={`/posts/${olderPost.id}`} rel="prev">
						{olderImg && <img src={olderImg} alt="" loading="lazy" />}
						<span class="nav-below-caption">
							<em>Previous</em>
							<span class="nav-below-title">{olderPost.data.title}</span>
						</span>
					</a>
				) : (
					<div class="nav-below-prev nav-below-filler" aria-hidden="true">
						{heroImg && <img src={heroImg} alt="" loading="lazy" />}
					</div>
				)}
				{newerPost ? (
					<a class="nav-below-next" href={`/posts/${newerPost.id}`} rel="next">
						{newerImg && <img src={newerImg} alt="" loading="lazy" />}
						<span class="nav-below-caption">
							<em>Next</em>
							<span class="nav-below-title">{newerPost.data.title}</span>
						</span>
					</a>
				) : (
					<div class="nav-below-next nav-below-filler" aria-hidden="true">
						{heroImg && <img src={heroImg} alt="" loading="lazy" />}
					</div>
				)}
			</nav>
		)
	}

	{
		(olderPost || newerPost) && (
			<nav id="nav-fixed" aria-label="Post navigation">
				{olderPost && (
					<div class="nav-previous">
						<a
							href={`/posts/${olderPost.id}`}
							rel="prev"
							aria-label={`Previous post: ${olderPost.data.title}`}
						>
							<i aria-hidden="true">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
							</i>
							<span class="nav-fixed-title">{olderPost.data.title}</span>
						</a>
					</div>
				)}
				{newerPost && (
					<div class="nav-next">
						<a
							href={`/posts/${newerPost.id}`}
							rel="next"
							aria-label={`Next post: ${newerPost.data.title}`}
						>
							<span class="nav-fixed-title">{newerPost.data.title}</span>
							<i aria-hidden="true">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
							</i>
						</a>
					</div>
				)}
			</nav>
		)
	}

	<script>
		// Reveal the floating prev/next tabs once the reader scrolls in
		// (demo #nav-fixed.nav-fixed-show, toggled past 30px).
		const navFixed = document.getElementById("nav-fixed");
		if (navFixed) {
			const onNavScroll = () =>
				navFixed.classList.toggle("nav-fixed-show", window.scrollY > 30);
			onNavScroll();
			window.addEventListener("scroll", onNavScroll, { passive: true });

			// The full-bleed image prev/next band reaches the screen edges,
			// so the floating tabs would collide with its captions. Retract
			// the tabs while that band is on screen — it does the same job
			// there anyway.
			const navBelow = document.getElementById("nav-below");
			if (navBelow && "IntersectionObserver" in window) {
				new IntersectionObserver(
					(entries) =>
						navFixed.classList.toggle("nav-below-visible", entries[0].isIntersecting),
					{ rootMargin: "0px 0px -20% 0px" }
				).observe(navBelow);
			}
		}
	</script>

	<script>
		// Demo comment form: labels are visually hidden, so mirror each
		// field's label text into its placeholder (with a * for required
		// fields). The <label> stays in the DOM for screen readers.
		for (const field of document.querySelectorAll<HTMLElement>(".ec-comment-form-field")) {
			const label = field.querySelector<HTMLElement>(":scope > span");
			const control = field.querySelector<HTMLInputElement | HTMLTextAreaElement>(
				"input, textarea"
			);
			if (label && control && !control.getAttribute("placeholder")) {
				const req = control.hasAttribute("required") ? " *" : "";
				control.setAttribute("placeholder", label.textContent!.trim() + req);
			}
		}
	</script>
</Base>

<style>
	/* Article container */
	.article {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	/* Hero image - full width within container */
	.article-hero {
		margin: var(--spacing-16) var(--spacing-6);
		border-radius: var(--radius-lg);
		overflow: hidden;
		background: var(--color-surface);
	}

	.article-hero img {
		width: 100%;
		height: auto;
		max-height: 500px;
		object-fit: cover;
	}

	/* Bravada blog layout: one white card (article + related + comments)
	   beside the sidebar. The white starts right below the hero — no tint
	   gap — and everything that isn't the sidebar sits inside it. */
	.post-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) var(--sidebar-width);
		gap: 0;
		max-width: var(--wide-width);
		margin: 0 auto var(--spacing-16);
		padding: 0 var(--spacing-6);
	}

	/* Sidebar: a 2.2em inner gutter (like the layout pages) insets the
	   widgets to ~285px, and a top pad drops the first widget to the
	   white card's content line instead of touching the hero. */
	.post-grid > :global(.bravada-sidebar) {
		padding: clamp(1.75em, 4vw, 3.5em) 0 0 2.2em;
	}

	.post-main {
		min-width: 0;
		background: var(--color-surface);
		padding: clamp(1.75em, 4vw, 3.5em);
	}

	/* Post tags footer (demo: tag links under the article) */
	.article-tags {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.5em;
		margin-top: var(--spacing-10);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
		font-size: var(--font-size-sm);
	}

	.article-tags-label {
		color: var(--color-muted);
	}

	.article-tag {
		color: var(--color-gold);
		text-decoration: none;
	}

	.article-tag:hover {
		color: var(--color-teal);
	}

	.article-header {
		margin-bottom: var(--spacing-10);
	}

	.article-header .article-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		column-gap: var(--spacing-3);
		row-gap: var(--spacing-1);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
	}

	.article-meta-byline {
		font-weight: 500;
		color: var(--color-text-secondary);
	}

	.article-title {
		font-size: clamp(2rem, 5vw, var(--font-size-5xl));
		font-weight: var(--font-weight-display);
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--spacing-4);
	}

	.article-excerpt {
		font-size: var(--font-size-xl);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
	}

	/* Article content typography */
	.article-content {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
	}

	.article-content :global(p) {
		margin-bottom: 1.5em;
	}

	.article-content :global(h2) {
		font-size: var(--font-size-2xl);
		margin-top: 2.5em;
		margin-bottom: 0.75em;
		scroll-margin-top: calc(var(--nav-height) + var(--spacing-4));
	}

	.article-content :global(h3) {
		font-size: var(--font-size-xl);
		margin-top: 2em;
		margin-bottom: 0.5em;
		scroll-margin-top: calc(var(--nav-height) + var(--spacing-4));
	}

	.article-content :global(blockquote) {
		margin: 2em 0;
		padding: var(--spacing-4) var(--spacing-6);
		border-left: 3px solid var(--color-border);
		background: var(--color-bg-subtle);
		border-radius: 0 var(--radius) var(--radius) 0;
		color: var(--color-text-secondary);
		font-style: italic;
	}

	.article-content :global(pre) {
		margin: 2em 0;
		padding: var(--spacing-5);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		line-height: 1.6;
	}

	.article-content :global(code) {
		font-family: var(--font-mono);
		font-size: 0.9em;
		background: var(--color-surface);
		padding: 0.2em 0.4em;
		border-radius: var(--radius);
	}

	.article-content :global(pre code) {
		background: none;
		padding: 0;
	}

	.article-content :global(ul),
	.article-content :global(ol) {
		margin-bottom: 1.5em;
		padding-left: 1.5em;
	}

	.article-content :global(li) {
		margin-bottom: 0.5em;
	}

	.article-content :global(img) {
		margin: 2em 0;
		border-radius: var(--radius-lg);
	}

	.article-content :global(hr) {
		margin: 3em 0;
		border: none;
		border-top: 1px solid var(--color-border);
	}

	.article-content :global(a) {
		color: var(--color-brand);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-thickness: 1px;
	}

	.article-content :global(a:hover) {
		text-decoration-thickness: 2px;
	}

	/* Signature section heading (Related Posts + the comments title):
	   Playfair 700 at 1.2em on the gold strip — like every other section
	   title on the site. */
	.section-title {
		display: inline-block;
		margin: 0 0 1.2em;
		font-family: var(--font-heading);
		font-size: 1.2rem;
		font-weight: 700;
		line-height: 1.6;
		background-image: var(--gold-scrim);
		background-repeat: no-repeat;
		background-size: 100% 0.4em;
		background-position: 0 90%;
	}

	/* We render our own "N Comments" / "Leave a Reply" headings (demo
	   text + scrim), so hide EmDash's built-in "No comments yet" one. */
	.post-comments :global(.ec-comments-heading) {
		display: none;
	}

	.reply-title {
		margin-top: var(--spacing-10);
	}

	/* Related posts — image cards constrained inside the white card */
	.related-posts {
		margin-top: var(--spacing-12);
		padding-top: var(--spacing-10);
		border-top: 1px solid var(--color-border);
	}

	.related-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-6);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.related-item {
		display: flex;
		flex-direction: column;
	}

	/* Holds the framed image and the floating comment chip (no clip) */
	.related-thumb {
		position: relative;
	}

	/* Demo picture frame: a 5px white border + soft drop shadow, like the
	   footer and shop-sidebar thumbnails */
	.related-thumb-frame {
		display: block;
		overflow: hidden;
		line-height: 0;
		border: 5px solid var(--color-surface);
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
	}

	.related-thumb-frame img {
		width: 100%;
		aspect-ratio: 512 / 300;
		object-fit: cover;
		transition: transform 0.4s ease-out;
	}

	.related-item:hover .related-thumb-frame img,
	.related-item:focus-within .related-thumb-frame img {
		transform: scale(1.05);
	}

	/* Demo comment chip: white bg, gold text, sitting just above the
	   top-right of the frame (always shown when comments are enabled) */
	.related-comments {
		position: absolute;
		top: -10px;
		right: 10px;
		display: inline-flex;
		align-items: center;
		gap: 0.3em;
		padding: 0.2em 0.55em;
		background: var(--color-surface);
		color: var(--color-gold);
		border-radius: 2px;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
		font-size: 0.72rem;
		line-height: 1.5;
		text-decoration: none;
	}

	.related-comments:hover {
		color: var(--color-teal);
	}

	.related-name {
		margin-top: 0.9em;
		font-family: var(--font-heading);
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.3;
		color: var(--color-heading);
		text-decoration: none;
	}

	.related-name:hover {
		color: var(--color-gold);
	}

	.related-date {
		margin: 0.35em 0 0;
		font-size: 0.8rem;
		color: var(--color-muted);
	}

	/* Comments live inside the white card, below related posts */
	.post-comments {
		margin-top: var(--spacing-12);
		padding-top: var(--spacing-10);
		border-top: 1px solid var(--color-border);
	}

	.post-comments :global(.ec-comments) {
		--ec-comment-border: 1px solid var(--color-border);
	}

	.post-comments :global(.ec-comment-author) {
		color: var(--color-text);
	}

	.post-comments :global(.ec-comment-date) {
		font-family: var(--font-mono);
		color: var(--color-muted);
	}

	.post-comments :global(.ec-comment-body) {
		color: var(--color-text);
	}

	/* Demo comment fields: flat #f0f0f0, no border, square. The labels are
	   hidden and their text moves into the placeholder (set by the script
	   below), so no tightening is needed — the demo padding stands. */
	.post-comments :global(.ec-comment-form-field input),
	.post-comments :global(.ec-comment-form-field textarea) {
