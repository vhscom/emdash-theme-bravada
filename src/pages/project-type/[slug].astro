---
import { getTerm, decodeSlug } from "emdash";
import ProjectTermArchive from "../../components/ProjectTermArchive.astro";

const slug = decodeSlug(Astro.params.slug);
const term = slug ? await getTerm("project-type", slug) : null;

if (!term) {
	return Astro.rewrite("/404");
}
---

<ProjectTermArchive taxonomy="project-type" term={term} />
