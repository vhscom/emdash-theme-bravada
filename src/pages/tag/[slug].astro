---
import { getTerm, decodeSlug } from "emdash";
import PostTermArchive from "../../components/PostTermArchive.astro";

const slug = decodeSlug(Astro.params.slug);
const term = slug ? await getTerm("tag", slug) : null;

if (!term) {
	return Astro.rewrite("/404");
}
---

<PostTermArchive taxonomy="tag" term={term} />
